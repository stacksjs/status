<!--
  App navigation for every post-login dashboard page: the marketing nav's
  sibling (same brand block, blur backdrop, theme toggle) with section
  links and the session controls. Expects AUTH_USER (nullable) and
  NAV_ACTIVE ('monitors' | 'incidents' | 'status-pages' | 'settings')
  from the including page's server script. The logout form is stamped by
  csrf-forms.js, loaded in app-head.stx.
-->
<nav class="app-nav">
  <div class="app-shell app-nav-inner">
    <a class="brand" href="/" data-no-router aria-label="UptimeStatus home">
      <span class="brand-mark">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.5 12h3.5l2-5 3 10 2-7 1.5 3.5h6.5"/></svg>
      </span>
      <span class="brand-name">UptimeStatus</span>
    </a>
    @if (AUTH_USER && typeof SWITCHABLE_TEAMS !== 'undefined' && SWITCHABLE_TEAMS && SWITCHABLE_TEAMS.length > 1)
      <details class="team-switch">
        <summary aria-label="Switch workspace">
          <span class="team-switch-cur">{{ SEE_ALL ? 'All teams' : (ACTIVE_TEAM_NAME || 'Workspace') }}</span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="m6 9 6 6 6-6"/></svg>
        </summary>
        <div class="team-switch-menu" role="menu">
          <p class="team-switch-head">Switch workspace</p>
          @if (IS_SUPER)
            <form method="POST" action="/api/team-forms/switch" role="none">
              <input type="hidden" name="team_id" value="all">
              <button type="submit" class="team-switch-item {{ SEE_ALL ? 'is-active' : '' }}" role="menuitem">
                <span>All teams</span>
                @if (SEE_ALL)<span class="team-switch-chk">&#10003;</span>@endif
              </button>
            </form>
          @endif
          @foreach (SWITCHABLE_TEAMS as team)
            <form method="POST" action="/api/team-forms/switch" role="none">
              <input type="hidden" name="team_id" value="{{ team.id }}">
              <button type="submit" class="team-switch-item {{ (!SEE_ALL && team.id === TEAM_ID) ? 'is-active' : '' }}" role="menuitem">
                <span class="ellipsis">{{ team.name }}</span>
                @if (!SEE_ALL && team.id === TEAM_ID)<span class="team-switch-chk">&#10003;</span>@endif
              </button>
            </form>
          @endforeach
        </div>
      </details>
    @endif
    <div class="app-links" aria-label="Dashboard sections">
      <a href="/dashboard" class="{{ NAV_ACTIVE === 'overview' ? 'active' : '' }}" data-no-router>Overview</a>
      <a href="/dashboard/monitors" class="{{ NAV_ACTIVE === 'monitors' ? 'active' : '' }}" data-no-router>Monitors</a>
      <a href="/dashboard/incidents" class="{{ NAV_ACTIVE === 'incidents' ? 'active' : '' }}" data-no-router>Incidents</a>
      <a href="/dashboard/status-pages" class="{{ NAV_ACTIVE === 'status-pages' ? 'active' : '' }}" data-no-router>Status pages</a>
      <a href="/dashboard/settings/notifications" class="{{ NAV_ACTIVE === 'settings' ? 'active' : '' }}" data-no-router>Settings</a>
    </div>
    <div class="app-nav-right">
      <button class="theme-toggle" id="theme-toggle" type="button" aria-label="Toggle color theme">
        <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2m0 14v2m9-9h-2M5 12H3m15.36 6.36-1.41-1.41M6.05 6.05 4.64 4.64m14.72 0-1.41 1.41M6.05 17.95l-1.41 1.41"/><circle cx="12" cy="12" r="4.5"/></svg>
        <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M20 14.5A8.5 8.5 0 0 1 9.5 4a8.5 8.5 0 1 0 10.5 10.5Z"/></svg>
      </button>
      @if (AUTH_USER)
        <span class="app-user" title="{{ AUTH_USER.email }}">{{ AUTH_USER.email }}</span>
        <form method="POST" action="/api/logout">
          <button class="button sm" type="submit">Sign out</button>
        </form>
      @endif
      @if (!AUTH_USER)
        <a class="button sm primary" href="/login" data-no-router>Sign in</a>
      @endif
    </div>
  </div>
</nav>
<style>
  .team-switch { position: relative; }
  .team-switch > summary {
    display: inline-flex; align-items: center; gap: 0.35rem; cursor: pointer; list-style: none;
    padding: 0.35rem 0.6rem; border: 1px solid var(--border); border-radius: 999px;
    font-size: 0.85rem; font-weight: 600; color: var(--fg); background: var(--surface, transparent);
    max-width: 220px;
  }
  .team-switch > summary::-webkit-details-marker { display: none; }
  .team-switch > summary:hover { border-color: var(--border-strong); }
  .team-switch > summary svg { width: 14px; height: 14px; color: var(--muted); flex: none; }
  .team-switch-cur { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .team-switch[open] > summary svg { transform: rotate(180deg); }
  .team-switch-menu {
    position: absolute; top: calc(100% + 6px); left: 0; z-index: 60; min-width: 240px; max-width: 320px;
    padding: 0.35rem; border: 1px solid var(--border); border-radius: 12px;
    background: var(--surface); box-shadow: 0 18px 40px -14px rgba(11,15,13,0.28);
  }
  .team-switch-head { margin: 0.25rem 0.5rem 0.35rem; font-size: 0.72rem; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; color: var(--muted); }
  .team-switch-menu form { margin: 0; }
  .team-switch-item {
    display: flex; align-items: center; justify-content: space-between; gap: 0.5rem; width: 100%;
    padding: 0.5rem 0.55rem; border: 0; border-radius: 8px; cursor: pointer;
    font: inherit; font-size: 0.9rem; text-align: left; color: var(--fg); background: transparent;
  }
  .team-switch-item:hover { background: var(--surface-2); }
  .team-switch-item.is-active { color: var(--accent); font-weight: 600; }
  .team-switch-chk { color: var(--accent); flex: none; }
</style>
<script>
  (function () {
    // Close the workspace switcher when clicking outside it.
    document.addEventListener('click', function (e) {
      document.querySelectorAll('details.team-switch[open]').forEach(function (d) {
        if (!d.contains(e.target)) d.removeAttribute('open')
      })
    })
  })();
  (function () {
    var toggle = document.getElementById('theme-toggle')
    if (!toggle) return
    toggle.addEventListener('click', function () {
      var html = document.documentElement
      var current = html.getAttribute('data-theme')
      var prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches
      var isDark = current === 'dark' || (current !== 'light' && prefersDark)
      var next = isDark ? 'light' : 'dark'
      html.setAttribute('data-theme', next)
      try { localStorage.setItem('uptimestatus-theme', next) } catch (err) {}
    })
  })()
</script>
