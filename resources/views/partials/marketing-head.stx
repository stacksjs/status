  /* ------------------------------------------------------------------ */
  /* Responsive                                                          */
  /* ------------------------------------------------------------------ */

  @media (max-width: 900px) {
    .site-shell { width: min(100% - 32px, 720px); }

    .split-row { grid-template-columns: minmax(0, 1fr); }
    .split-row.flip > .split-panel { order: 0; }

