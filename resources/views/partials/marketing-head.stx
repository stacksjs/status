  .table-note {
    margin: 0.85rem 0 0;
    color: var(--muted);
    font-size: 0.82rem;
  }

  /* Verdict cards ("choose X if...") */
  .verdict-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.25rem;
  }
  .verdict-card {
    padding: 1.6rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
