<!--
  Shared head assets for every marketing subpage (features/*, for/*,
  compare). The homepage (index.stx) predates this partial and keeps its
  own inline copy of the same design system. Tokens here are copied from
  it verbatim and must stay in sync if the brand ever changes. Subpages
  include this once instead of carrying 1,300 duplicated CSS lines each.

  Expects the including page to define appName in its server script.
  NOTE: never write a literal script tag inside these comments. The stx
  processor scans for script blocks before comment semantics apply, and
  it will eat the comment closer, turning the rest of the page into one
  giant HTML comment (that bug shipped once already).

  The theme pre-paint script sits AFTER the font links on purpose: a
  script block at the very top of a partial is treated as the partial's
  component script and stripped from the output.
-->
<link rel="icon" href="/favicon.svg" type="image/svg+xml">
<link rel="icon" href="/favicon-32.png" type="image/png" sizes="32x32">
<link rel="apple-touch-icon" href="/apple-touch-icon.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<script>
  // Apply a stored theme override before first paint to avoid a flash of
  // the wrong theme (same mechanism as index.stx).
  (function () {
    try {
      var stored = localStorage.getItem('uptimestatus-theme')
      if (stored === 'light' || stored === 'dark') {
        document.documentElement.setAttribute('data-theme', stored)
      }
    }
    catch (err) {}
  })()
</script>
<style>
  :root {
    color-scheme: light;
    --bg: #fbfbfa;
    --surface: #ffffff;
    --surface-2: #f2f3f1;
    --fg: #0b0f0d;
    --muted: #5c6864;
    --border: rgba(11, 15, 13, 0.1);
    --border-strong: rgba(11, 15, 13, 0.18);
    --accent: #2563eb;
    --accent-fg: #ffffff;
    --accent-soft: rgba(37, 99, 235, 0.09);
    --success: #059669;
    --success-soft: rgba(5, 150, 105, 0.12);
    --violet: #6d5efc;
    --amber: #d97706;
    --shadow: 0 20px 50px -18px rgba(11, 15, 13, 0.22);
    --radius: 16px;
    --radius-sm: 10px;
    --font-display: "Space Grotesk", ui-sans-serif, system-ui, sans-serif;
    --font-body: "Inter", ui-sans-serif, system-ui, sans-serif;
    --font-mono: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
  }

  @media (prefers-color-scheme: dark) {
    html:not([data-theme="light"]) {
      color-scheme: dark;
      --bg: #080b0a;
      --surface: #101413;
      --surface-2: #161b19;
      --fg: #f2f5f3;
      --muted: #97a39d;
      --border: rgba(255, 255, 255, 0.08);
      --border-strong: rgba(255, 255, 255, 0.15);
      --accent: #60a5fa;
      --accent-fg: #071630;
      --accent-soft: rgba(96, 165, 250, 0.14);
      --success: #2fe6a6;
      --success-soft: rgba(47, 230, 166, 0.14);
      --violet: #a196ff;
      --amber: #fbbf24;
      --shadow: 0 24px 60px -16px rgba(0, 0, 0, 0.55);
    }
  }

  html[data-theme="dark"] {
    color-scheme: dark;
    --bg: #080b0a;
    --surface: #101413;
    --surface-2: #161b19;
    --fg: #f2f5f3;
    --muted: #97a39d;
    --border: rgba(255, 255, 255, 0.08);
    --border-strong: rgba(255, 255, 255, 0.15);
    --accent: #60a5fa;
    --accent-fg: #071630;
    --accent-soft: rgba(96, 165, 250, 0.14);
    --success: #2fe6a6;
    --success-soft: rgba(47, 230, 166, 0.14);
    --violet: #a196ff;
    --amber: #fbbf24;
    --shadow: 0 24px 60px -16px rgba(0, 0, 0, 0.55);
  }

  * { box-sizing: border-box; }

  html {
    background: var(--bg);
    overflow-x: hidden;
    scroll-behavior: smooth;
  }

  body {
    min-width: 320px;
    min-height: 100vh;
    margin: 0;
    overflow-x: hidden;
    color: var(--fg);
    background: var(--bg);
    font-family: var(--font-body);
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  a { color: inherit; text-decoration: none; }
  img { max-width: 100%; display: block; }
  ::selection { background: var(--accent-soft); }

  .site-shell {
    width: min(1180px, calc(100% - 40px));
    margin: 0 auto;
  }

  /* ------------------------------------------------------------------ */
  /* Navigation                                                          */
  /* ------------------------------------------------------------------ */

  .site-nav {
    position: sticky;
    top: 0;
    z-index: 40;
    border-bottom: 1px solid var(--border);
    background: color-mix(in srgb, var(--bg) 78%, transparent);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 66px;
    gap: 1rem;
  }

  .brand {
    display: inline-flex;
    gap: 0.6rem;
    align-items: center;
    min-width: 0;
  }

  .brand-mark {
    position: relative;
    display: grid;
    flex: 0 0 auto;
    place-items: center;
    width: 30px;
    height: 30px;
    border-radius: 8px;
    color: var(--accent-fg);
    background: var(--accent);
  }
  /* Live "pulse": a radar ring emanates from the mark while the waveform
     gives a double heartbeat, so the logo reads as an active signal rather
     than a static tile. Disabled under reduced-motion. */
  .brand-mark::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    animation: brand-ping 2.6s cubic-bezier(0, 0, 0.2, 1) infinite;
  }
  .brand-mark svg { width: 16px; height: 16px; transform-origin: center; animation: brand-beat 2.6s ease-in-out infinite; }
  @keyframes brand-ping {
    0% { box-shadow: 0 0 0 0 color-mix(in srgb, var(--accent) 55%, transparent); }
    70%, 100% { box-shadow: 0 0 0 9px transparent; }
  }
  @keyframes brand-beat {
    0%, 45%, 100% { transform: scale(1); }
    10% { transform: scale(1.16); }
    20% { transform: scale(1); }
    30% { transform: scale(1.1); }
    40% { transform: scale(1); }
  }
  @media (prefers-reduced-motion: reduce) {
    .brand-mark::after, .brand-mark svg { animation: none; }
  }

  .brand-name {
    font-family: var(--font-display);
    font-size: 1.12rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1;
  }

  .nav-links {
    display: flex;
    gap: 1.75rem;
    align-items: center;
    color: var(--muted);
    font-size: 0.9rem;
    font-weight: 500;
  }
  .nav-links a:hover { color: var(--fg); }
  .nav-links a[aria-current="true"] { color: var(--fg); }

  /* ------------------------------------------------------------------ */
  /* Mega menu (Features / Use cases hover panels)                       */
  /* ------------------------------------------------------------------ */
  .nav-item { position: relative; display: inline-flex; align-items: center; }
  .nav-item > a { display: inline-flex; align-items: center; gap: 0.28rem; }
  .nav-item > a .caret {
    width: 13px; height: 13px; opacity: 0.7;
    transition: transform 0.18s ease;
  }
  .nav-item:hover > a .caret,
  .nav-item:focus-within > a .caret { transform: rotate(180deg); }

  .nav-mega {
    position: absolute;
    top: 100%;
    left: 0;                        /* open rightward from the trigger's left edge */
    padding-top: 12px;              /* transparent bridge so hover survives the gap */
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    z-index: 60;
  }
  .nav-item:hover > .nav-mega,
  .nav-item:focus-within > .nav-mega {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }
  .nav-mega-inner {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
    box-shadow: var(--shadow);
    padding: 1.1rem;
    transform: translateY(6px);
    transition: transform 0.18s ease;
  }
  .nav-item:hover > .nav-mega .nav-mega-inner,
  .nav-item:focus-within > .nav-mega .nav-mega-inner { transform: translateY(0); }

  .nav-mega.features .nav-mega-inner {
    display: grid;
    grid-template-columns: repeat(3, minmax(150px, 1fr));
    gap: 0.4rem 1.75rem;
    width: min(90vw, 620px);
  }
  .nav-mega.usecases .nav-mega-inner {
    display: grid;
    grid-template-columns: repeat(2, minmax(210px, 1fr));
    gap: 0.2rem 0.5rem;
    width: min(90vw, 500px);
  }

  .mega-group h5 {
    margin: 0.15rem 0 0.35rem;
    color: var(--muted);
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .mega-group a {
    display: block;
    padding: 0.32rem 0;
    color: var(--fg);
    font-size: 0.875rem;
    font-weight: 500;
    line-height: 1.2;
  }
  .mega-group a:hover { color: var(--accent); }

  .mega-link {
    display: grid;
    gap: 0.1rem;
    padding: 0.5rem 0.6rem;
    border-radius: var(--radius-sm);
  }
  .mega-link:hover { background: var(--surface-2); }
  .mega-link strong { color: var(--fg); font-size: 0.88rem; font-weight: 600; }
  .mega-link span { color: var(--muted); font-size: 0.78rem; line-height: 1.35; }

  .mega-foot {
    grid-column: 1 / -1;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem 1rem;
    margin-top: 0.6rem;
    padding-top: 0.7rem;
    border-top: 1px solid var(--border);
  }
  .mega-foot .mega-foot-links { display: flex; flex-wrap: wrap; gap: 0.35rem 1.1rem; }
  .mega-foot .mega-foot-links a { color: var(--muted); font-size: 0.82rem; font-weight: 500; }
  .mega-foot .mega-foot-links a:hover { color: var(--fg); }
  .mega-foot .mega-all {
    display: inline-flex; align-items: center; gap: 0.3rem;
    color: var(--accent); font-size: 0.82rem; font-weight: 600;
  }
  .mega-foot .mega-all svg { width: 14px; height: 14px; }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 0.65rem;
  }

  .theme-toggle {
    display: inline-grid;
    place-items: center;
    width: 38px;
    height: 38px;
    flex: 0 0 auto;
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--fg);
    background: var(--surface);
    cursor: pointer;
  }
  .theme-toggle:hover { border-color: var(--border-strong); }
  .theme-toggle svg { width: 17px; height: 17px; }
  .theme-toggle .icon-sun { display: none; }
  html[data-theme="dark"] .theme-toggle .icon-moon { display: none; }
  html[data-theme="dark"] .theme-toggle .icon-sun { display: block; }
  @media (prefers-color-scheme: dark) {
    html:not([data-theme="light"]) .theme-toggle .icon-moon { display: none; }
    html:not([data-theme="light"]) .theme-toggle .icon-sun { display: block; }
  }

  /* ------------------------------------------------------------------ */
  /* Buttons                                                             */
  /* ------------------------------------------------------------------ */

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    min-height: 44px;
    padding: 0 1.2rem;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-sm);
    color: var(--fg);
    font: inherit;
    font-size: 0.92rem;
    font-weight: 600;
    background: var(--surface);
    cursor: pointer;
    white-space: nowrap;
  }
  .button:hover { border-color: var(--fg); }
  .button:active { transform: translateY(1px); }
  .button svg { width: 17px; height: 17px; }

  .button.primary {
    border-color: var(--accent);
    color: var(--accent-fg);
    background: var(--accent);
  }
  .button.primary:hover { filter: brightness(1.05); border-color: var(--accent); }
  .button.wide { width: 100%; }

  /* ------------------------------------------------------------------ */
  /* Page hero (marketing subpages)                                      */
  /* ------------------------------------------------------------------ */

  .page-hero {
    max-width: 46rem;
    padding: clamp(3rem, 7vw, 5.5rem) 0 clamp(1.5rem, 3vw, 2.5rem);
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    margin-bottom: 1.5rem;
    padding: 0.4rem 0.85rem;
    border: 1px solid var(--border-strong);
    border-radius: 999px;
    color: var(--muted);
    font-size: 0.8rem;
    font-weight: 600;
  }
  .badge .dot {
    width: 7px;
    height: 7px;
    border-radius: 999px;
    background: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-soft);
  }

  .page-title {
    margin: 0 0 1.15rem;
    font-family: var(--font-display);
    font-size: clamp(2.1rem, 4.4vw, 3.3rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.08;
  }
  .page-title .accent-word { color: var(--accent); }

  .page-lead {
    max-width: 40rem;
    margin: 0;
    color: var(--muted);
    font-size: 1.12rem;
    line-height: 1.65;
  }

  .page-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 2rem;
  }

  /* ------------------------------------------------------------------ */
  /* Sections                                                            */
  /* ------------------------------------------------------------------ */

  .section { padding: clamp(3rem, 6vw, 5rem) 0; }

  .section-head {
    max-width: 42rem;
    margin: 0 auto 2.75rem;
    text-align: center;
  }
  .section-head.left {
    margin: 0 0 2.5rem;
    text-align: left;
  }

  .eyebrow {
    display: block;
    margin-bottom: 0.75rem;
    color: var(--accent);
    font-size: 0.82rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .section-title {
    margin: 0 0 0.85rem;
    font-family: var(--font-display);
    font-size: clamp(1.7rem, 3vw, 2.4rem);
    font-weight: 600;
    letter-spacing: -0.015em;
    line-height: 1.15;
  }

  .section-copy {
    margin: 0;
    color: var(--muted);
    font-size: 1.05rem;
    line-height: 1.65;
  }
  .section-copy a {
    color: var(--fg);
    font-weight: 600;
    border-bottom: 1px solid var(--border-strong);
  }
  .section-copy a:hover { color: var(--accent); border-color: var(--accent); }

  /* Split row: text beside a panel. Cap consecutive use at two (see the
     design pre-flight); break runs with checklists, bands, or grids. */
  .split-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: center;
    padding: clamp(2rem, 4vw, 3rem) 0;
  }
  .split-row.flip > .split-panel { order: -1; }

  .split-copy h2, .split-copy h3 {
    margin: 0 0 0.75rem;
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 2.4vw, 1.9rem);
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.2;
  }
  .split-copy p {
    margin: 0 0 1rem;
    color: var(--muted);
    font-size: 1rem;
    line-height: 1.65;
  }
  .split-copy p:last-child { margin-bottom: 0; }
  .split-copy a {
    color: var(--fg);
    font-weight: 600;
    border-bottom: 1px solid var(--border-strong);
  }
  .split-copy a:hover { color: var(--accent); border-color: var(--accent); }

  /* ------------------------------------------------------------------ */
  /* Panels: product-style data cards (mirror the real dashboard UI)     */
  /* ------------------------------------------------------------------ */

  .panel {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
    box-shadow: var(--shadow);
    overflow: hidden;
  }

  .panel-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--border);
  }
  .panel-top strong {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 600;
  }

  .pill {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--success);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }
  .pill .dot { width: 6px; height: 6px; border-radius: 999px; background: var(--success); }
  .pill.warn { color: var(--amber); }
  .pill.warn .dot { background: var(--amber); }
  .pill.down { color: #ef4444; }
  .pill.down .dot { background: #ef4444; }

  .panel-list { padding: 0.5rem; display: grid; gap: 0.15rem; }

  .panel-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.85rem 0.85rem;
    border-radius: 10px;
  }
  .panel-row:hover { background: var(--surface-2); }

  .panel-row-main {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    min-width: 0;
  }
  .panel-row-main .dot {
    flex: 0 0 auto;
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: var(--success);
    box-shadow: 0 0 0 4px var(--success-soft);
  }
  .panel-row-main .dot.warn { background: var(--amber); box-shadow: 0 0 0 4px rgba(217, 119, 6, 0.12); }
  .panel-row-main .dot.down { background: #ef4444; box-shadow: 0 0 0 4px rgba(239, 68, 68, 0.12); }

  .panel-row-name { font-size: 0.9rem; font-weight: 600; }
  .panel-row-sub {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    color: var(--muted);
  }
  .panel-row-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex: 0 0 auto;
    font-size: 0.78rem;
    color: var(--muted);
  }

  .panel-body { padding: 1.25rem; }

  .spark {
    display: flex;
    align-items: flex-end;
    gap: 2px;
    height: 22px;
  }
  .spark span {
    width: 3px;
    border-radius: 1px;
    background: var(--success);
    opacity: 0.55;
  }

  .uptime-bars {
    display: flex;
    gap: 2px;
    align-items: stretch;
    height: 30px;
  }
  .uptime-bars span {
    flex: 1 1 0;
    min-width: 1px;
    border-radius: 2px;
    background: var(--success);
    opacity: 0.75;
  }
  .uptime-bars span.warn { background: var(--amber); }
  .uptime-bars span.down { background: #ef4444; }

  /* Dark terminal/code panel (multiline sibling of the homepage oss-code) */
  .code-panel {
    padding: 1.25rem 1.5rem;
    border-radius: var(--radius);
    color: #8ce8bb;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    line-height: 1.7;
    background: #0d1210;
    overflow-x: auto;
  }
  .code-panel .cmt { color: #5c6864; }
  .code-panel .str { color: #c5b3ff; }
  .code-panel pre { margin: 0; font: inherit; }

  /* ------------------------------------------------------------------ */
  /* Cards & grids                                                       */
  /* ------------------------------------------------------------------ */

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.25rem;
  }
  .feature-grid.two { grid-template-columns: repeat(2, minmax(0, 1fr)); }

  .feature-card {
    padding: 1.85rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
  }
  a.feature-card { transition: border-color 0.15s ease; }
  a.feature-card:hover { border-color: var(--accent); }

  .feature-icon {
    display: grid;
    place-items: center;
    width: 44px;
    height: 44px;
    margin-bottom: 1.35rem;
    border-radius: 11px;
    color: var(--accent);
    background: var(--accent-soft);
  }
  .feature-icon svg { width: 22px; height: 22px; }

  .feature-card h3 {
    margin: 0 0 0.5rem;
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 600;
  }
  .feature-card p {
    margin: 0;
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.6;
  }
  .feature-card .card-more {
    display: inline-block;
    margin-top: 1rem;
    color: var(--accent);
    font-size: 0.88rem;
    font-weight: 600;
  }

  /* Checklist: dense fact rows without card chrome */
  .check-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem 2.5rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .check-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.65rem;
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--muted);
  }
  .check-list li strong { color: var(--fg); font-weight: 600; }
  .check-list svg {
    flex: 0 0 auto;
    width: 18px;
    height: 18px;
    margin-top: 0.15rem;
    color: var(--accent);
  }

  /* ------------------------------------------------------------------ */
  /* Comparison table                                                    */
  /* ------------------------------------------------------------------ */

  .compare-scroll {
    overflow-x: auto;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
  }

  .compare-table {
    width: 100%;
    min-width: 760px;
    border-collapse: collapse;
    font-size: 0.9rem;
  }
  .compare-table th,
  .compare-table td {
    padding: 0.8rem 1rem;
    border-bottom: 1px solid var(--border);
    text-align: center;
    white-space: nowrap;
  }
  .compare-table tr:last-child th,
  .compare-table tr:last-child td { border-bottom: 0; }
  .compare-table thead th {
    position: sticky;
    top: 0;
    background: var(--surface-2);
