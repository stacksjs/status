<!--
  Shared head assets for every post-login dashboard page. Tactical
  Telemetry design system (see .claude/skills/stacks-design-brutalist):
  dark CRT substrate, monospace uppercase micro-type, hazard red for
  everything wrong, phosphor green STRICTLY for operational readouts,
  zero border-radius anywhere. Pages are served as fragments, so this
  ships style and font links inline in the body (valid, and the only
  option without a head to write into).

  Expects nothing from the including page. The command bar lives in
  telemetry-nav.stx and DOES expect AUTH_USER (every dashboard page
  already resolves it).

  NOTE: never write a literal script tag inside these comments; the stx
  processor eats the comment closer (see marketing-head.stx).
-->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
<script src="/assets/scripts/csrf-forms.js" defer></script>
<style>
  :root {
    --sub: #0A0A0A;          /* deactivated CRT substrate */
    --panel: #121212;        /* raised compartment */
    --panel-2: #181818;      /* hover compartment */
    --ink: #EAEAEA;          /* white phosphor */
    --dim: #8C8C8C;          /* secondary readout */
    --faint: #4A4A4A;        /* structural annotation */
    --line: #262626;         /* hairline grid */
    --hazard: #FF2A2A;       /* aviation red: alerts, DOWN, structural strikes */
    --phosphor: #4AF626;     /* terminal green: OPERATIONAL readouts ONLY */
    --mono: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
    --macro: "Archivo Black", ui-sans-serif, system-ui, sans-serif;
  }

  html { background: var(--sub); }
  body {
    margin: 0;
    min-height: 100vh;
    color: var(--ink);
    background: var(--sub);
    font-family: var(--mono);
    font-size: 13px;
    line-height: 1.4;
  }
  * { box-sizing: border-box; border-radius: 0 !important; }
  a { color: inherit; text-decoration: none; }
  ::selection { background: var(--hazard); color: var(--sub); }

  /* CRT scanlines + static grain: fixed, pointer-events-none, never on a
     scrolling container (repaint cost). Subtle by design. */
  .crt-overlay {
    position: fixed;
    inset: 0;
    z-index: 90;
    pointer-events: none;
    background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0, 0, 0, 0.14) 2px, rgba(0, 0, 0, 0.14) 4px);
    opacity: 0.5;
  }

  .tl-shell {
    width: min(1280px, calc(100% - 32px));
    margin: 0 auto;
  }

  /* ------------------------------------------------------------------ */
  /* Command bar                                                         */
  /* ------------------------------------------------------------------ */

  .tl-bar {
    border-bottom: 2px solid var(--ink);
    background: var(--sub);
  }
  .tl-bar-inner {
    display: flex;
    align-items: stretch;
    justify-content: space-between;
    gap: 16px;
    min-height: 52px;
  }
  .tl-brand {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--macro);
    font-size: 15px;
    letter-spacing: -0.02em;
    text-transform: uppercase;
  }
  .tl-brand .sig { color: var(--hazard); }

  .tl-nav {
    display: flex;
    align-items: stretch;
  }
  .tl-nav a {
    display: flex;
    align-items: center;
    padding: 0 14px;
    border-left: 1px solid var(--line);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--dim);
  }
  .tl-nav a:last-child { border-right: 1px solid var(--line); }
  .tl-nav a:hover { color: var(--ink); background: var(--panel); }
  .tl-nav a.active {
    color: var(--sub);
    background: var(--ink);
  }

  .tl-session {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--faint);
  }
  .tl-session form { display: contents; }
  .tl-session button {
    border: 1px solid var(--line);
    background: transparent;
    color: var(--dim);
    font: inherit;
    letter-spacing: inherit;
    text-transform: inherit;
    padding: 5px 10px;
    cursor: pointer;
  }
  .tl-session button:hover { border-color: var(--hazard); color: var(--hazard); }

  /* ------------------------------------------------------------------ */
  /* Page banner: macro type + right meta                                */
  /* ------------------------------------------------------------------ */

  .tl-banner {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    padding: 40px 0 20px;
    border-bottom: 2px solid var(--hazard);
  }
  .tl-title {
    margin: 0;
    font-family: var(--macro);
    font-size: clamp(2.6rem, 6vw, 4.5rem);
    line-height: 0.9;
    letter-spacing: -0.03em;
    text-transform: uppercase;
  }
  .tl-banner-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 4px;
    padding-bottom: 6px;
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--dim);
    text-align: right;
    white-space: nowrap;
  }
  .tl-banner-meta .hz { color: var(--hazard); }

  /* ------------------------------------------------------------------ */
  /* Stat strip: gap-px compartments                                     */
  /* ------------------------------------------------------------------ */

  .tl-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
    margin: 24px 0;
  }
  .tl-stat {
    background: var(--panel);
    padding: 14px 16px;
  }
  .tl-stat dt {
    margin: 0 0 6px;
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--faint);
  }
  .tl-stat dd {
    margin: 0;
    font-size: 26px;
    font-weight: 700;
    line-height: 1;
  }
  .tl-stat dd small {
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 0.08em;
    color: var(--dim);
  }
  .tl-stat .ok { color: var(--phosphor); }
  .tl-stat .bad { color: var(--hazard); }

  /* ------------------------------------------------------------------ */
  /* Filter rails                                                        */
  /* ------------------------------------------------------------------ */

  .tl-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    padding: 14px 0;
    border-bottom: 1px solid var(--line);
    margin-bottom: 0;
  }
  .tl-filter-group {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 2px;
  }
  .tl-filter-group .lbl {
    margin-right: 8px;
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--faint);
  }
  .tl-chip {
    display: inline-block;
    padding: 4px 10px;
    border: 1px solid var(--line);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--dim);
  }
  .tl-chip:hover { color: var(--ink); border-color: var(--dim); }
  .tl-chip.active {
    color: var(--sub);
    background: var(--ink);
    border-color: var(--ink);
    font-weight: 700;
  }

  /* ------------------------------------------------------------------ */
  /* Telemetry table                                                     */
  /* ------------------------------------------------------------------ */

  .tl-table {
    display: grid;
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
  }
  .tl-thead, .tl-row {
    display: grid;
    gap: 1px;
    background: inherit;
  }
  .tl-cell {
    display: flex;
    align-items: center;
    gap: 8px;
    min-width: 0;
    padding: 12px 14px;
    background: var(--panel);
    font-size: 12px;
  }
  .tl-thead .tl-cell {
    padding: 8px 14px;
    background: var(--sub);
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--faint);
  }
  a.tl-row:hover .tl-cell { background: var(--panel-2); }
  .tl-cell .sub { color: var(--dim); font-size: 10px; letter-spacing: 0.04em; }
  .tl-cell.num { justify-content: flex-end; font-variant-numeric: tabular-nums; }

  .tl-ellipsis { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

  /* Status readouts. Phosphor green is reserved for UP and nothing else. */
  .st { font-weight: 700; font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; white-space: nowrap; }
  .st::before { content: "■ "; font-size: 9px; }
  .st-up { color: var(--phosphor); }
  .st-degraded { color: var(--hazard); }
  .st-down { color: var(--sub); background: var(--hazard); padding: 2px 8px; }
  .st-down::before { content: "▮ "; }
  .st-unknown { color: var(--faint); }

  /* ------------------------------------------------------------------ */
  /* Panels, forms, actions                                              */
  /* ------------------------------------------------------------------ */

  .tl-panel {
    border: 1px solid var(--line);
    background: var(--panel);
    margin: 24px 0;
  }
  .tl-panel-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 10px 16px;
    border-bottom: 1px solid var(--line);
    background: var(--sub);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .tl-panel-head .hz { color: var(--hazard); }
  .tl-panel-body { padding: 16px; }

  .tl-empty {
    padding: 56px 24px;
    border: 1px solid var(--line);
    background: var(--panel);
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .tl-empty .big { display: block; font-size: 15px; font-weight: 700; margin-bottom: 8px; }
  .tl-empty .why { color: var(--dim); font-size: 11px; }

  .tl-label {
    display: block;
    margin: 0 0 6px;
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--faint);
  }
  .tl-input, .tl-select, .tl-textarea {
    width: 100%;
    padding: 10px 12px;
    border: 1px solid var(--line);
    background: var(--sub);
    color: var(--ink);
    font: inherit;
    font-size: 12px;
  }
  .tl-input:focus, .tl-select:focus, .tl-textarea:focus {
    outline: 1px solid var(--ink);
    outline-offset: -1px;
    border-color: var(--ink);
  }

  .tl-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 18px;
    border: 1px solid var(--ink);
    background: var(--ink);
    color: var(--sub);
    font: inherit;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
  }
  .tl-btn:hover { background: var(--sub); color: var(--ink); }
  .tl-btn.ghost { background: transparent; color: var(--ink); border-color: var(--line); }
  .tl-btn.ghost:hover { border-color: var(--ink); }
  .tl-btn.danger { background: var(--hazard); border-color: var(--hazard); color: var(--sub); }
  .tl-btn.danger:hover { background: transparent; color: var(--hazard); }

  /* Uptime bars: rectangular ticks, no radius */
  .tl-bars { display: flex; gap: 2px; align-items: stretch; height: 26px; }
  .tl-bars span { flex: 1 1 0; min-width: 1px; background: var(--phosphor); opacity: 0.85; }
  .tl-bars span.warn, .tl-bars span.down { background: var(--hazard); }
  .tl-bars span.unknown { background: var(--faint); opacity: 0.4; }

  .tl-footnote {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    padding: 24px 0 40px;
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--faint);
  }

  @media (max-width: 760px) {
    .tl-bar-inner { flex-wrap: wrap; padding: 8px 0; }
    .tl-nav { order: 3; width: 100%; border-top: 1px solid var(--line); }
    .tl-nav a { flex: 1 1 auto; justify-content: center; padding: 10px 6px; }
    .tl-banner { flex-direction: column; align-items: flex-start; }
    .tl-banner-meta { align-items: flex-start; text-align: left; white-space: normal; }

    /* An odd cell count in a 2-up grid leaves a dead slot painted in the
       hairline color; stretch the last compartment across the row instead. */
    .tl-stats { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .tl-stats .tl-stat:last-child:nth-child(odd) { grid-column: 1 / -1; }

    /* Fixed column tracks (inline styles) cannot fit 375px; the table
       scrolls sideways inside its own frame instead of squashing. */
    .tl-table { overflow-x: auto; }
    .tl-thead, .tl-row { min-width: 680px; }
  }
</style>
