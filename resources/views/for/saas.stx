  </head>
  <body>
    @include('../partials/marketing-nav.stx')

    <main>
      <section class="site-shell">
        <div class="page-hero">
          <span class="badge"><span class="dot"></span> Built for SaaS teams</span>
          <h1 class="page-title">Trust is the product. <span class="accent-word">Monitor it.</span></h1>
          <p class="page-lead">
            Every blip makes a customer ask “is it down?” Catch outages in 30 seconds, watch the jobs that bill people, and let your status page answer first.
          </p>
          <div class="page-actions">
            <a class="button primary" href="/register" data-no-router>Start monitoring free</a>
            <a class="button" href="https://github.com/stacksjs/status" target="_blank" rel="noopener">Read the source</a>
          </div>
