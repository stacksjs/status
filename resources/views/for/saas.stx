    <meta property="og:title" content="Monitoring for SaaS teams | {{ appName }}">
    <meta property="og:description" content="30 second checks, heartbeats on revenue-critical jobs, and a public status page with email subscribers and an RSS feed.">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://uptime-status.org/for/saas">
