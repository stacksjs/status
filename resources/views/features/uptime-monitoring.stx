<script server>
const appName = process.env.APP_NAME || 'UptimeStatus'

const included = [
  { title: 'Checks every 30 seconds', text: 'on the Pro plan, from six global regions. Self-hosted installs choose their own interval and worker regions.' },
  { title: 'HTTP, TCP, and ping', text: 'monitor a URL, a raw port, or a host. Each check type gets its own page under Features.' },
  { title: 'Full result history', text: 'status code, response time, error message, and probe region stored for every single check.' },
  { title: 'Automatic incidents', text: 'a failing monitor opens a timeline incident, notifies your channels, and updates your status page.' },
  { title: 'Maintenance windows', text: 'schedule planned work so your status page shows maintenance instead of an outage.' },
  { title: 'Response-time tracking', text: 'every check records latency, so slowdowns are visible long before a hard failure.' },
]

const faqs = [
  {
    q: 'How fast will I know my site is down?',
    a: 'Pro checks run as often as every 30 seconds, so detection plus notification typically lands within a minute of the failure. Self-hosted installs control their own interval floor.',
  },
  {
    q: 'What counts as "down"?',
    a: 'A check fails when the endpoint does not return a successful response in time: connection errors, timeouts, and unexpected HTTP status codes all open an incident. Every failure stores the status code and error message so you can see exactly what the probe saw.',
  },
  {
    q: 'Do I need to install an agent?',
    a: 'No. Uptime checks probe from the outside, exactly like your users reach you. If you also want CPU and memory metrics from inside a server, the optional server metrics agent covers that separately.',
  },
  {
    q: 'Can I monitor endpoints behind a firewall?',
    a: 'Self-host the open-source version inside your network and your checks run from wherever you deploy the workers. The hosted plan probes from the public internet.',
  },
  {
    q: 'What happens during planned deploys?',
    a: 'Create a maintenance window. Your status page shows scheduled maintenance for that period instead of an outage, and the incident timeline stays clean.',
  },
]

const related = [
  { title: 'Performance monitoring', text: 'Automatic p95 regression detection against a 7-day baseline catches slowdowns before they become outages.', href: '/features/performance-monitoring' },
  { title: 'Status pages', text: 'A branded status page on your own domain answers “is it down?” before support tickets do.', href: '/features/status-pages' },
  { title: 'Notifications', text: 'Email, Slack, PagerDuty, Opsgenie, SMS, and six more channels, routed the way your team works.', href: '/features/notifications' },
]
</script>

