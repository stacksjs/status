                  <div class="panel-row-main"><span class="dot down"></span><div><div class="panel-row-name">HTTP 502</div><div class="panel-row-sub">upstream connect error</div></div></div>
                  <div class="panel-row-meta"><span>84ms &middot; eu-central</span></div>
                </div>
                <div class="panel-row">
                  <div class="panel-row-main"><span class="dot down"></span><div><div class="panel-row-name">HTTP 502</div><div class="panel-row-sub">upstream connect error</div></div></div>
