<!--
  Monitor detail -- dashboard page (stacksjs/status#1 Phase 8).

  Server-rendered, same convention as monitors/index.stx and the public
  status pages. Charts are hand-rolled inline SVG computed server-side
  from CheckResult rows rather than @stacksjs/charts + a client script +
  useChart() (the framework's real, working convention elsewhere) --
  this app's own dashboard pages hit an unresolved client-hydration bug
  earlier in this project (see monitors/index.stx's header comment), so
  charts here stay on the same proven server-rendered path rather than
  re-risking that. Revisit once the underlying stx bug is confirmed
  fixed.

  Visual language: Tactical Telemetry (.claude/skills/stacks-design-
  brutalist) via partials/telemetry-head.stx. Phosphor green marks
  OPERATIONAL readouts and telemetry traces only; hazard red marks
  everything wrong (and destructive actions).
-->
<script server>
const { config } = require('@stacksjs/config')
const { Auth, sessionUser } = require('@stacksjs/auth')
// Dialect-agnostic DB access (sqlite self-hosted / networked Postgres hosted).
const { db } = require('@stacksjs/database')

const ROLE_PRIORITY = { owner: 0, admin: 1 }

// Auth + team resolution (stacksjs/status#1 Phase 9 follow-up) -- see
// monitors/index.stx's copy of this block for the full rationale.
// Resolving to `TEAM_ID = -1` on any auth failure means the query below
// naturally returns no rows, reusing the existing "Monitor not found"
// state rather than needing a separate unauthenticated branch. This
// query previously had NO team check at all -- any authenticated (or
// even the wrong-team) visitor could view any monitor's full detail,
// incidents, SSL cert, and notification channels by guessing/enumerating
// its id.
async function resolveAuthTeam() {
  const guardName = config.auth?.default || 'api'
  const guard = config.auth?.guards?.[guardName] || {}
  const driver = guard.driver || 'token'
  const cookieName = driver === 'session' ? 'session_id' : (config.auth?.defaultTokenName || 'auth-token')

  const cookieValue = (typeof globalThis !== 'undefined' && globalThis.requestContext)
    ? globalThis.requestContext.cookie(cookieName)
    : null
  if (!cookieValue) return null

  const user = driver === 'session' ? await sessionUser(cookieValue) : await Auth.getUserFromToken(cookieValue)
  if (!user || !user.id) return null

  const memberships = await db.selectFrom('team_members')
    .where('user_id', '=', user.id).where('status', '=', 'active').execute()
  memberships.sort((a, b) => (ROLE_PRIORITY[a.role] ?? 2) - (ROLE_PRIORITY[b.role] ?? 2))
  const membership = memberships[0]

  return { user, teamId: membership ? membership.team_id : null }
}

const AUTH = await resolveAuthTeam()
const AUTH_USER = AUTH ? AUTH.user : null
const TEAM_ID = AUTH && AUTH.teamId ? AUTH.teamId : -1
const NAV_ACTIVE = 'monitors'

const appUrl = process.env.APP_URL || 'http://localhost:3000'

const monitorId = (typeof id !== 'undefined' && id) ? Number(id) : 0
const monitor = monitorId ? (await db.selectFrom('monitors').where('id', '=', monitorId).where('team_id', '=', TEAM_ID).limit(1).execute())[0] || null : null

// Display helpers (Tactical Telemetry) -- same contract as
// monitors/index.stx: stClass/stLabel drive the <data class="st ...">
// readouts, agoLabel renders relative timestamps in uppercase mono.
function stClass(status) {
  if (status === 'up') return 'st st-up'
  if (status === 'degraded') return 'st st-degraded'
  if (status === 'down') return 'st st-down'
  return 'st st-unknown'
}

function stLabel(status) {
  if (status === 'up') return 'UP'
  if (status === 'degraded') return 'DEGRADED'
  if (status === 'down') return 'DOWN'
  if (status === 'paused') return 'PAUSED'
  return 'UNKNOWN'
}

function agoLabel(iso) {
  if (!iso) return 'NEVER'
  const s = Math.max(0, Math.floor((Date.now() - new Date(iso).getTime()) / 1000))
  if (s < 60) return s + 'S AGO'
  if (s < 3600) return Math.floor(s / 60) + 'M AGO'
  if (s < 86400) return Math.floor(s / 3600) + 'H AGO'
  return Math.floor(s / 86400) + 'D AGO'
}

function formatDate(iso) {
  if (!iso) return '--'
  const d = new Date(iso)
  if (isNaN(d.getTime())) return '--'
  return d.toLocaleString('en-US', { month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' })
}

const recentChecks = monitor
  ? await db.selectFrom('check_results').where('monitor_id', '=', monitor.id).orderBy('checked_at', 'desc').limit(20).execute()
  : []

const incidents = monitor
  ? await db.selectFrom('incidents').where('monitor_id', '=', monitor.id).orderBy('started_at', 'desc').limit(20).execute()
  : []

// Assigned channels: the pivot rows joined back to their channels in JS.
let assignedChannels = []
if (monitor) {
  const links = await db.selectFrom('monitor_notification_channels').where('monitor_id', '=', monitor.id).execute()
  const ids = links.map(l => l.notification_channel_id)
  const chans = ids.length ? await db.selectFrom('notification_channels').whereIn('id', ids).execute() : []
  assignedChannels = chans
    .map(c => ({ id: c.id, name: c.name, type: c.type }))
    .sort((a, b) => String(a.name).localeCompare(String(b.name)))
}
const assignedChannelIds = assignedChannels.map((c) => c.id)
let availableChannels = []
if (monitor) {
  const teamChans = await db.selectFrom('notification_channels').where('team_id', '=', monitor.team_id).execute()
  const assignedSet = new Set(assignedChannelIds)
  availableChannels = teamChans
    .filter(c => !assignedSet.has(c.id))
    .map(c => ({ id: c.id, name: c.name, type: c.type }))
    .sort((a, b) => String(a.name).localeCompare(String(b.name)))
}

// Response-time sparkline: oldest -> newest, last 50 checks. `>= 0`
// excludes NULL response times portably.
const chartChecks = monitor
  ? (await db.selectFrom('check_results').where('monitor_id', '=', monitor.id).where('response_time_ms', '>=', 0).orderBy('checked_at', 'desc').limit(50).execute()).reverse()
  : []

function buildSparkline(values, width, height) {
  if (values.length === 0) return ''
  const max = Math.max(...values, 1)
  const min = Math.min(...values, 0)
  const range = max - min || 1
  const stepX = values.length > 1 ? width / (values.length - 1) : 0
  return values
    .map((v, i) => {
      const x = (i * stepX).toFixed(1)
      const y = (height - ((v - min) / range) * height).toFixed(1)
      return `${i === 0 ? 'M' : 'L'}${x},${y}`
    })
    .join(' ')
}

const sparklineWidth = 600
const sparklineHeight = 80
const sparklinePath = buildSparkline(chartChecks.map((c) => c.response_time_ms), sparklineWidth, sparklineHeight)
const latestResponseTime = chartChecks.length > 0 ? chartChecks[chartChecks.length - 1].response_time_ms : null
const avgResponseTime = chartChecks.length > 0 ? Math.round(chartChecks.reduce((sum, c) => sum + c.response_time_ms, 0) / chartChecks.length) : null

// Time-range filter + request-volume/CPU/RAM aggregation. `range` picks
// both the lookback window and the bucket granularity (hourly buckets for
// 24h so the chart isn't just 1 bar, daily buckets for the wider windows).
const query = (typeof __stxServeSearch !== 'undefined' && __stxServeSearch) ? new URLSearchParams(__stxServeSearch) : new URLSearchParams()
const range = query.get('range') || '24h'
const RANGE_CONFIG = {
  '24h': { sinceMs: 24 * 60 * 60 * 1000, granularity: 'hour' },
  '7d': { sinceMs: 7 * 24 * 60 * 60 * 1000, granularity: 'day' },
  '30d': { sinceMs: 30 * 24 * 60 * 60 * 1000, granularity: 'day' },
}
const { sinceMs, granularity } = RANGE_CONFIG[range] || RANGE_CONFIG['24h']
const since = new Date(Date.now() - sinceMs).toISOString()

function rangeUrl(r) {
  const p = new URLSearchParams(query)
  p.set('range', r)
  return '/dashboard/monitors/' + monitorId + '?' + p.toString()
}

// Request-volume + CPU/RAM aggregation, bucketed in JS (portable) rather
// than via SQLite's strftime/json_extract. `hour` buckets reproduce the
// old `%Y-%m-%d %H:00` key; `day` buckets reproduce `date(checked_at)`.
// CPU/RAM come from each row's JSON metadata; the average ignores rows
// that don't carry a numeric sample, matching SQL's AVG-skips-NULL.
function bucketKey(iso) {
  const s = String(iso)
  return granularity === 'hour' ? `${s.slice(0, 10)} ${s.slice(11, 13)}:00` : s.slice(0, 10)
}
let volumeBuckets = []
if (monitor) {
  const rows = await db.selectFrom('check_results').where('monitor_id', '=', monitor.id).where('checked_at', '>=', since).execute()
  const byBucket = new Map()
  for (const r of rows) {
    const key = bucketKey(r.checked_at)
    let b = byBucket.get(key)
    if (!b) { b = { bucket: key, request_count: 0, cpuSum: 0, cpuN: 0, ramSum: 0, ramN: 0 }; byBucket.set(key, b) }
    b.request_count++
    let meta = {}
    try { meta = JSON.parse(r.metadata || '{}') } catch {}
    if (typeof meta.cpuPercent === 'number') { b.cpuSum += meta.cpuPercent; b.cpuN++ }
    if (typeof meta.ramPercent === 'number') { b.ramSum += meta.ramPercent; b.ramN++ }
  }
  volumeBuckets = [...byBucket.values()]
    .sort((a, b) => (a.bucket < b.bucket ? -1 : a.bucket > b.bucket ? 1 : 0))
    .map(b => ({ bucket: b.bucket, request_count: b.request_count, avg_cpu: b.cpuN ? b.cpuSum / b.cpuN : null, avg_ram: b.ramN ? b.ramSum / b.ramN : null }))
}

const totalChecksInRange = volumeBuckets.reduce((sum, b) => sum + b.request_count, 0)

function buildBarChart(values, width, height) {
  if (values.length === 0) return []
  const max = Math.max(...values, 1)
  const barWidth = width / values.length
  return values.map((v, i) => ({
    x: (i * barWidth).toFixed(1),
    y: (height - (v / max) * height).toFixed(1),
    w: (barWidth * 0.8).toFixed(1),
    h: ((v / max) * height || 0).toFixed(1),
  }))
}

const volumeChartWidth = 600
const volumeChartHeight = 80
const volumeBars = buildBarChart(volumeBuckets.map((b) => b.request_count), volumeChartWidth, volumeChartHeight)

// CPU/RAM line paths -- only meaningful when this monitor reports metrics.
const cpuPath = monitor && monitor.reports_metrics
  ? buildSparkline(volumeBuckets.map((b) => b.avg_cpu || 0), volumeChartWidth, volumeChartHeight)
  : ''
const ramPath = monitor && monitor.reports_metrics
  ? buildSparkline(volumeBuckets.map((b) => b.avg_ram || 0), volumeChartWidth, volumeChartHeight)
  : ''

// 90-day uptime bar: one segment per day, 'up'/'degraded'/'down'/'unknown'.
// Grouped by day in JS (portable) rather than SQLite date()/SUM(CASE).
const since90 = new Date(Date.now() - 90 * 86400000).toISOString().slice(0, 10)
const dailyMap = {}
if (monitor) {
  const rows = await db.selectFrom('check_results').where('monitor_id', '=', monitor.id).where('checked_at', '>=', since90).execute()
  for (const r of rows) {
    const day = String(r.checked_at).slice(0, 10)
    let d = dailyMap[day]
    if (!d) { d = { day, down_count: 0, degraded_count: 0, total: 0 }; dailyMap[day] = d }
    d.total++
    if (r.status === 'down') d.down_count++
    else if (r.status === 'degraded') d.degraded_count++
  }
}

const uptimeDays = []
for (let i = 89; i >= 0; i--) {
  const d = new Date()
  d.setDate(d.getDate() - i)
  const key = d.toISOString().slice(0, 10)
  const row = dailyMap[key]
  let dayStatus = 'unknown'
  if (row) {
    if (row.down_count > 0) dayStatus = 'down'
    else if (row.degraded_count > 0) dayStatus = 'degraded'
    else dayStatus = 'up'
  }
  uptimeDays.push({ day: key, status: dayStatus })
}

// Maps a day status onto the .tl-bars tick classes (default tick is
// phosphor = up; warn/down are hazard; unknown is faint).
function dayTickClass(status) {
  if (status === 'degraded') return 'warn'
  if (status === 'down') return 'down'
  if (status === 'unknown') return 'unknown'
  return ''
}

const totalDaysWithData = uptimeDays.filter((d) => d.status !== 'unknown').length
const upDays = uptimeDays.filter((d) => d.status === 'up').length
const uptimePercent = totalDaysWithData > 0 ? ((upDays / totalDaysWithData) * 100).toFixed(2) : null

// Per-type detail panel.
const sslCertificate = monitor && monitor.type === 'ssl'
  ? (await db.selectFrom('ssl_certificates').where('monitor_id', '=', monitor.id).orderBy('created_at', 'desc').limit(1).execute())[0] || null
  : null

const dnsSnapshots = monitor && monitor.type === 'dns'
  ? await db.selectFrom('dns_snapshots').where('monitor_id', '=', monitor.id).orderBy('checked_at', 'desc').limit(10).execute()
  : []

const latestCrawl = monitor && monitor.type === 'broken_links'
  ? (await db.selectFrom('crawls').where('monitor_id', '=', monitor.id).orderBy('started_at', 'desc').limit(1).execute())[0] || null
  : null
const crawlBrokenPages = latestCrawl
  ? await db.selectFrom('crawled_pages').where('crawl_id', '=', latestCrawl.id).where('is_broken_link', '=', true).limit(20).execute()
  : []
const crawlMixedContentPages = latestCrawl
  ? await db.selectFrom('crawled_pages').where('crawl_id', '=', latestCrawl.id).where('is_mixed_content', '=', true).limit(20).execute()
  : []

const lighthouseReports = monitor && monitor.type === 'lighthouse'
  ? await db.selectFrom('lighthouse_reports').where('monitor_id', '=', monitor.id).orderBy('checked_at', 'desc').limit(10).execute()
  : []
const latestLighthouse = lighthouseReports[0] || null
const previousLighthouse = lighthouseReports[1] || null
const lighthouseRegression = latestLighthouse && previousLighthouse && (latestLighthouse.performance_score < previousLighthouse.performance_score - 10)

const latestPortScan = monitor && monitor.type === 'port_scan'
  ? (await db.selectFrom('port_scan_results').where('monitor_id', '=', monitor.id).orderBy('checked_at', 'desc').limit(1).execute())[0] || null
  : null
let portScanOpen = []
let portScanExpected = []
if (latestPortScan) {
  try { portScanOpen = JSON.parse(latestPortScan.open_ports || '[]') } catch {}
  try { portScanExpected = JSON.parse(latestPortScan.expected_ports || '[]') } catch {}
}

const generatedAt = new Date().toISOString().replace('T', ' ').slice(0, 19)
</script>

@include('../partials/telemetry-head.stx')
@include('../partials/telemetry-nav.stx')

<style>
  /* Page-specific: key/value readout grid + terminal transcript block,
     both on telemetry-head tokens. No radius anywhere (head resets it). */
  .mon-kv {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
  }
  .mon-kv > div { background: var(--sub); padding: 12px 14px; }
  .mon-kv dt {
    margin: 0 0 6px;
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--faint);
  }
  .mon-kv dd { margin: 0; font-size: 13px; font-weight: 700; overflow-wrap: anywhere; }
  .mon-kv dd.big { font-size: 22px; }
  .mon-pre {
    margin: 0;
    padding: 14px;
    border: 1px solid var(--line);
    background: var(--sub);
    color: var(--ink);
    font-family: var(--mono);
    font-size: 11px;
    line-height: 1.6;
    overflow-x: auto;
  }
  .mon-chart { display: block; width: 100%; height: 96px; }
  .mon-legend {
    margin-top: 10px;
    display: flex;
    gap: 16px;
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--dim);
  }
</style>

<main class="tl-shell">
  @if (!AUTH_USER)
    <div class="tl-empty" style="margin: 48px 0;">
      <span class="big">[ NO ACTIVE SESSION ]</span>
      <span class="why">Authentication required to read fleet telemetry. <a href="/login" data-no-router style="color: var(--ink); text-decoration: underline;">Sign in</a>.</span>
    </div>
  @endif

  @if (AUTH_USER && !monitor)
    <div class="tl-empty" style="margin: 48px 0;">
      <span class="big">[ UNIT NOT FOUND ]</span>
      <span class="why">No monitor with this id is registered to your team. <a href="/dashboard/monitors" style="color: var(--ink); text-decoration: underline;">Back to the fleet</a>.</span>
    </div>
  @endif

  @if (monitor)
    <nav style="padding-top: 20px;" aria-label="Breadcrumb">
      <a href="/dashboard/monitors" class="tl-chip">&lt; FLEET / MONITORS</a>
    </nav>

    <header class="tl-banner" style="padding-top: 20px;">
      <h1 class="tl-title" style="font-size: clamp(1.8rem, 4vw, 3rem); overflow-wrap: anywhere;">{{ monitor.name }}</h1>
      <div class="tl-banner-meta">
        <span><data class="{{ stClass(monitor.status) }}" value="{{ monitor.status }}">{{ stLabel(monitor.status) }}</data></span>
        <span style="max-width: 360px; overflow: hidden; text-overflow: ellipsis;">{{ monitor.url }}</span>
        <span>{{ monitor.type.replace('_', ' ') }} /// EVERY {{ monitor.check_interval_seconds }}S /// {{ monitor.enabled ? 'ENABLED' : 'DISABLED' }}</span>
        <span class="hz">UNIT #{{ monitor.id }} /// {{ generatedAt }} UTC</span>
      </div>
    </header>

    <dl class="tl-stats">
      <div class="tl-stat">
        <dt>[ 90-day uptime ]</dt>
        <dd class="{{ monitor.status === 'up' ? 'ok' : (monitor.status === 'down' || monitor.status === 'degraded' ? 'bad' : '') }}"><output>{{ uptimePercent !== null ? uptimePercent + '%' : '--' }}</output></dd>
      </div>
      <div class="tl-stat">
        <dt>[ Latest response ]</dt>
        <dd><output>{{ latestResponseTime !== null ? latestResponseTime + 'MS' : '--' }}</output></dd>
      </div>
      <div class="tl-stat">
        <dt>[ Avg response ]</dt>
        <dd><output>{{ avgResponseTime !== null ? avgResponseTime + 'MS' : '--' }}</output></dd>
      </div>
      <div class="tl-stat">
        <dt>[ Checks / {{ range }} ]</dt>
        <dd><output>{{ totalChecksInRange }}</output></dd>
      </div>
      <div class="tl-stat">
        <dt>[ Last check ]</dt>
        <dd><small style="font-size: 14px;"><time>{{ agoLabel(monitor.last_checked_at) }}</time></small></dd>
      </div>
    </dl>

    <div class="tl-filters">
      <div class="tl-filter-group">
        <span class="lbl">Range</span>
        <a href="{{ rangeUrl('24h') }}" class="tl-chip {{ range === '24h' ? 'active' : '' }}">24h</a>
        <a href="{{ rangeUrl('7d') }}" class="tl-chip {{ range === '7d' ? 'active' : '' }}">7d</a>
        <a href="{{ rangeUrl('30d') }}" class="tl-chip {{ range === '30d' ? 'active' : '' }}">30d</a>
      </div>
    </div>

    <section class="tl-panel" aria-label="90-day uptime">
      <div class="tl-panel-head">
        <span>[ UPTIME /// LAST 90 DAYS ]</span>
        <span class="{{ uptimePercent !== null && (monitor.status === 'down' || monitor.status === 'degraded') ? 'hz' : '' }}">{{ uptimePercent !== null ? uptimePercent + '% UP' : 'NO DATA' }}</span>
      </div>
      <div class="tl-panel-body">
        <div class="tl-bars">
          @foreach (uptimeDays as d)
            <span class="{{ dayTickClass(d.status) }}" title="{{ d.day }}: {{ d.status }}"></span>
          @endforeach
        </div>
        <div class="mon-legend">
          <span>90D AGO</span>
          <span style="margin-left: auto;">TODAY</span>
        </div>
      </div>
    </section>

    @if (volumeBars.length > 0)
      <section class="tl-panel" aria-label="Check volume">
        <div class="tl-panel-head">
          <span>[ CHECK VOLUME /// {{ range }} ]</span>
          <span>{{ totalChecksInRange }} CHECKS</span>
        </div>
        <div class="tl-panel-body">
          <svg viewBox="0 0 {{ volumeChartWidth }} {{ volumeChartHeight }}" class="mon-chart" preserveAspectRatio="none" role="img" aria-label="Check volume per bucket">
            @foreach (volumeBars as bar)
              <rect x="{{ bar.x }}" y="{{ bar.y }}" width="{{ bar.w }}" height="{{ bar.h }}" fill="var(--phosphor)" opacity="0.8"></rect>
            @endforeach
          </svg>
        </div>
      </section>
    @endif

    @if (monitor.reports_metrics && volumeBars.length > 0)
      <section class="tl-panel" aria-label="CPU and RAM usage">
        <div class="tl-panel-head">
          <span>[ HOST TELEMETRY /// CPU + RAM /// {{ range }} ]</span>
        </div>
        <div class="tl-panel-body">
          <svg viewBox="0 0 {{ volumeChartWidth }} {{ volumeChartHeight }}" class="mon-chart" preserveAspectRatio="none" role="img" aria-label="CPU and RAM traces">
            <path d="{{ cpuPath }}" fill="none" stroke="var(--phosphor)" stroke-width="2"></path>
            <path d="{{ ramPath }}" fill="none" stroke="var(--dim)" stroke-width="2"></path>
          </svg>
          <div class="mon-legend">
            <span style="color: var(--phosphor);">&#9632; CPU</span>
            <span style="color: var(--dim);">&#9632; RAM</span>
          </div>
        </div>
      </section>
    @endif

    @if (monitor.reports_metrics)
      <section class="tl-panel" aria-label="Agent setup">
        <div class="tl-panel-head">
          <span>[ AGENT SETUP ]</span>
          <span>CRON PUSH</span>
        </div>
        <div class="tl-panel-body">
          <p style="margin: 0 0 12px; font-size: 11px; color: var(--dim); text-transform: uppercase; letter-spacing: 0.08em;">Push CPU/RAM samples from this server on a cron schedule:</p>
          <pre class="mon-pre">CPU=$(top -bn1 | grep Cpu | awk '{print $2}')
read TOTAL USED &lt; &lt;(free -m | awk '/Mem:/{print $2, $3}')
curl -s -X POST {{ appUrl }}/api/agent/{{ monitor.metrics_token }}/metrics \
  -H 'Content-Type: application/json' \
  -d "{\"cpuPercent\":$CPU,\"ramPercent\":$(( USED * 100 / TOTAL )),\"ramUsedMb\":$USED,\"ramTotalMb\":$TOTAL}"</pre>
        </div>
      </section>
    @endif

    @if (chartChecks.length > 0)
      <section class="tl-panel" aria-label="Response time">
        <div class="tl-panel-head">
          <span>[ RESPONSE TRACE /// LAST {{ chartChecks.length }} CHECKS ]</span>
          <span>{{ latestResponseTime !== null ? 'NOW ' + latestResponseTime + 'MS' : '--' }} / AVG {{ avgResponseTime !== null ? avgResponseTime + 'MS' : '--' }}</span>
        </div>
        <div class="tl-panel-body">
          <svg viewBox="0 0 {{ sparklineWidth }} {{ sparklineHeight }}" class="mon-chart" preserveAspectRatio="none" role="img" aria-label="Response time sparkline">
            <path d="{{ sparklinePath }}" fill="none" stroke="var(--phosphor)" stroke-width="2"></path>
          </svg>
        </div>
      </section>
    @endif

    @if (monitor.type === 'ssl' && sslCertificate)
      <section class="tl-panel" aria-label="SSL certificate">
        <div class="tl-panel-head">
          <span>[ SSL CERTIFICATE ]</span>
        </div>
        <div class="tl-panel-body">
          <dl class="mon-kv" style="margin: 0;">
            <div><dt>Issuer</dt><dd>{{ sslCertificate.issuer }}</dd></div>
            <div><dt>Subject</dt><dd>{{ sslCertificate.subject }}</dd></div>
            <div><dt>Valid from</dt><dd>{{ formatDate(sslCertificate.valid_from) }}</dd></div>
            <div><dt>Expires</dt><dd>{{ formatDate(sslCertificate.expires_at) }}</dd></div>
          </dl>
        </div>
      </section>
    @endif

    @if (monitor.type === 'dns' && dnsSnapshots.length > 0)
      <section class="tl-panel" aria-label="DNS snapshots">
        <div class="tl-panel-head">
          <span>[ DNS SNAPSHOTS ]</span>
          <span>LAST {{ dnsSnapshots.length }}</span>
        </div>
        <section class="tl-table" style="border: 0;">
          <div class="tl-thead" style="grid-template-columns: 110px minmax(0, 1fr) 140px;">
            <span class="tl-cell">Record</span>
            <span class="tl-cell">Values</span>
            <span class="tl-cell num">Checked</span>
          </div>
          @foreach (dnsSnapshots as snap)
            <div class="tl-row" style="grid-template-columns: 110px minmax(0, 1fr) 140px;">
              <span class="tl-cell" style="font-weight: 700; text-transform: uppercase;">{{ snap.record_type }}</span>
              <span class="tl-cell sub" style="overflow-wrap: anywhere;">{{ snap.record_values }}</span>
              <span class="tl-cell num sub"><time>{{ formatDate(snap.checked_at) }}</time></span>
            </div>
          @endforeach
        </section>
      </section>
    @endif

    @if (monitor.type === 'broken_links' && latestCrawl)
      <section class="tl-panel" aria-label="Crawl report">
        <div class="tl-panel-head">
          <span>[ CRAWL REPORT ]</span>
          <span class="{{ latestCrawl.broken_links_count > 0 || latestCrawl.mixed_content_count > 0 ? 'hz' : '' }}">{{ latestCrawl.pages_crawled }} PAGES /// {{ latestCrawl.broken_links_count }} BROKEN /// {{ latestCrawl.mixed_content_count }} MIXED</span>
        </div>
        <div class="tl-panel-body">
          @if (crawlBrokenPages.length === 0 && crawlMixedContentPages.length === 0)
            <p style="margin: 0; font-size: 11px; color: var(--dim); text-transform: uppercase; letter-spacing: 0.08em;">No broken links or mixed content in the latest crawl.</p>
          @endif

          @if (crawlBrokenPages.length > 0)
            <p class="tl-label">[ Broken links, by source page ]</p>
            <div style="display: grid; gap: 1px; background: var(--line); border: 1px solid var(--line); margin-bottom: 16px;">
              @foreach (crawlBrokenPages as page)
                <div style="background: var(--sub); padding: 10px 12px; font-size: 11px;">
                  <span style="color: var(--hazard); font-weight: 700;">{{ page.status_code }}</span>
                  <span style="margin-left: 8px; overflow-wrap: anywhere;">{{ page.url }}</span>
                  <span class="sub" style="margin-left: 8px; color: var(--faint);">FOUND ON {{ page.found_on_url }}</span>
                </div>
              @endforeach
            </div>
          @endif

          @if (crawlMixedContentPages.length > 0)
            <p class="tl-label">[ Mixed content ]</p>
            <div style="display: grid; gap: 1px; background: var(--line); border: 1px solid var(--line);">
              @foreach (crawlMixedContentPages as page)
                <div style="background: var(--sub); padding: 10px 12px; font-size: 11px;">
                  <span style="overflow-wrap: anywhere;">{{ page.url }}</span>
                  <span class="sub" style="margin-left: 8px; color: var(--faint);">ON {{ page.found_on_url }}</span>
                </div>
              @endforeach
            </div>
          @endif
        </div>
      </section>
    @endif

    @if (monitor.type === 'lighthouse' && latestLighthouse)
      <section class="tl-panel" aria-label="Lighthouse scores">
        <div class="tl-panel-head">
          <span>[ LIGHTHOUSE SCORES ]</span>
          <span>{{ formatDate(latestLighthouse.checked_at) }}</span>
        </div>
        <div class="tl-panel-body">
          @if (lighthouseRegression)
            <p style="margin: 0 0 14px; padding: 10px 12px; border: 1px solid var(--hazard); color: var(--hazard); font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em;">[ PERF REGRESSION ] Performance score dropped more than 10 points since the previous run.</p>
          @endif
          <dl class="mon-kv" style="margin: 0;">
            <div><dt>Performance</dt><dd class="big">{{ latestLighthouse.performance_score }}</dd></div>
            <div><dt>Accessibility</dt><dd class="big">{{ latestLighthouse.accessibility_score }}</dd></div>
            <div><dt>SEO</dt><dd class="big">{{ latestLighthouse.seo_score }}</dd></div>
            <div><dt>Best practices</dt><dd class="big">{{ latestLighthouse.best_practices_score }}</dd></div>
          </dl>
        </div>
      </section>
    @endif

    @if (monitor.type === 'port_scan' && latestPortScan)
      <section class="tl-panel" aria-label="Port scan">
        <div class="tl-panel-head">
          <span>[ PORT SCAN ]</span>
          <span>{{ formatDate(latestPortScan.checked_at) }}</span>
        </div>
        <div class="tl-panel-body">
          <dl class="mon-kv" style="margin: 0;">
            <div><dt>Open ports</dt><dd>{{ portScanOpen.join(', ') || 'NONE' }}</dd></div>
            <div><dt>Expected ports</dt><dd>{{ portScanExpected.join(', ') || 'NONE CONFIGURED' }}</dd></div>
          </dl>
        </div>
      </section>
    @endif

    <section class="tl-panel" aria-label="Incident history">
      <div class="tl-panel-head">
        <span>[ INCIDENT LOG ]</span>
        <span class="{{ incidents.length > 0 ? 'hz' : '' }}">{{ incidents.length }} RECORDED</span>
      </div>
      @if (incidents.length === 0)
        <div class="tl-panel-body">
          <p style="margin: 0; font-size: 11px; color: var(--dim); text-transform: uppercase; letter-spacing: 0.08em;">No incidents recorded for this monitor.</p>
        </div>
      @endif
      @if (incidents.length > 0)
        <section class="tl-table" style="border: 0;">
          <div class="tl-thead" style="grid-template-columns: 120px minmax(0, 1.6fr) 140px 140px;">
            <span class="tl-cell">Status</span>
            <span class="tl-cell">Cause</span>
            <span class="tl-cell num">Started</span>
            <span class="tl-cell num">Resolved</span>
          </div>
          @foreach (incidents as incident)
            <div class="tl-row" style="grid-template-columns: 120px minmax(0, 1.6fr) 140px 140px;">
              <span class="tl-cell"><data class="{{ incident.resolved_at ? 'st st-unknown' : 'st st-down' }}" value="{{ incident.status }}">{{ incident.status.replace('_', ' ') }}</data></span>
              <span class="tl-cell tl-ellipsis">{{ incident.cause }}</span>
              <span class="tl-cell num sub"><time>{{ formatDate(incident.started_at) }}</time></span>
              <span class="tl-cell num sub"><time>{{ incident.resolved_at ? formatDate(incident.resolved_at) : '--' }}</time></span>
            </div>
          @endforeach
        </section>
      @endif
    </section>

    <section class="tl-panel" aria-label="Notification channels">
      <div class="tl-panel-head">
        <span>[ ALERT ROUTING ]</span>
        <span class="{{ assignedChannels.length === 0 ? 'hz' : '' }}">{{ assignedChannels.length }} CHANNEL{{ assignedChannels.length === 1 ? '' : 'S' }} ATTACHED</span>
      </div>
      <div class="tl-panel-body">
        @if (assignedChannels.length === 0)
          <p style="margin: 0 0 14px; font-size: 11px; color: var(--hazard); text-transform: uppercase; letter-spacing: 0.08em;">No channels attached: this monitor won't notify anyone on an incident.</p>
        @endif

        @if (assignedChannels.length > 0)
          <div style="display: grid; gap: 1px; background: var(--line); border: 1px solid var(--line); margin-bottom: 16px;">
            @foreach (assignedChannels as channel)
              <div style="display: flex; align-items: center; justify-content: space-between; gap: 16px; background: var(--sub); padding: 10px 12px;">
                <p style="margin: 0; font-size: 12px; font-weight: 700;">{{ channel.name }} <span style="font-weight: 400; color: var(--faint); text-transform: uppercase; letter-spacing: 0.08em; font-size: 10px;">{{ channel.type }}</span></p>
                <form method="POST" action="/api/notification-channel-forms/monitors/{{ monitor.id }}/remove">
                  <input type="hidden" name="channel_id" value="{{ channel.id }}" />
                  <button type="submit" class="tl-btn danger" style="padding: 5px 10px; font-size: 9px;">Remove</button>
                </form>
              </div>
            @endforeach
          </div>
        @endif

        @if (availableChannels.length > 0)
          <form method="POST" action="/api/notification-channel-forms/monitors/{{ monitor.id }}/assign">
            <label class="tl-label" for="mon-attach-channel">[ Attach a channel ]</label>
            <div style="display: flex; gap: 8px; align-items: stretch;">
              <select id="mon-attach-channel" name="channel_id" class="tl-select" style="flex: 1 1 auto;">
                @foreach (availableChannels as channel)
                  <option value="{{ channel.id }}">{{ channel.name }} ({{ channel.type }})</option>
                @endforeach
              </select>
              <button type="submit" class="tl-btn">Attach</button>
            </div>
          </form>
        @endif
        @if (availableChannels.length === 0 && assignedChannels.length === 0)
          <p style="margin: 0; font-size: 11px; color: var(--dim); text-transform: uppercase; letter-spacing: 0.08em;"><a href="/dashboard/settings/notifications" style="color: var(--ink); text-decoration: underline;">Add a notification channel</a> to attach one here.</p>
        @endif
      </div>
    </section>

    <section class="tl-panel" aria-label="Recent check results">
      <div class="tl-panel-head">
        <span>[ CHECK TRANSCRIPT /// LAST {{ recentChecks.length }} ]</span>
      </div>
      @if (recentChecks.length === 0)
        <div class="tl-panel-body">
          <p style="margin: 0; font-size: 11px; color: var(--dim); text-transform: uppercase; letter-spacing: 0.08em;">No checks recorded yet. First probe lands within {{ monitor.check_interval_seconds }}s of enabling.</p>
        </div>
      @endif
      @if (recentChecks.length > 0)
        <section class="tl-table" style="border: 0;">
          <div class="tl-thead" style="grid-template-columns: 120px minmax(0, 1.6fr) 70px 100px 90px 130px;">
            <span class="tl-cell">Status</span>
            <span class="tl-cell">Message</span>
            <span class="tl-cell num">Code</span>
            <span class="tl-cell">Region</span>
            <span class="tl-cell num">Resp</span>
            <span class="tl-cell num">Checked</span>
          </div>
          @foreach (recentChecks as check)
            <div class="tl-row" style="grid-template-columns: 120px minmax(0, 1.6fr) 70px 100px 90px 130px;">
              <span class="tl-cell"><data class="{{ stClass(check.status) }}" value="{{ check.status }}">{{ stLabel(check.status) }}</data></span>
              <span class="tl-cell sub tl-ellipsis">{{ check.message }}</span>
              <span class="tl-cell num sub"><samp>{{ check.status_code !== null && check.status_code !== undefined ? check.status_code : '--' }}</samp></span>
              <span class="tl-cell sub" style="text-transform: uppercase; letter-spacing: 0.08em;">{{ check.region || '--' }}</span>
              <span class="tl-cell num"><samp>{{ check.response_time_ms !== null ? check.response_time_ms + 'MS' : '--' }}</samp></span>
              <span class="tl-cell num sub"><time>{{ formatDate(check.checked_at) }}</time></span>
            </div>
          @endforeach
        </section>
      @endif
    </section>

    <footer class="tl-footnote">
      <span>UNIT #{{ monitor.id }} /// {{ monitor.uuid }}</span>
      <span>UPTIME///STATUS © TELEMETRY CONSOLE</span>
    </footer>
  @endif
</main>
