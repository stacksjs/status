<!--
  Onboarding -- dashboard page (stacksjs/status#1 Phase 8). A checklist
  rather than a multi-step wizard: each step re-derives its own
  completion state from real data on every load (has the team created a
  monitor? a notification channel? a status page?) instead of tracked
  wizard/session state, so it can't drift out of sync with what's
  actually true and there's nothing to build/maintain for
  resuming-partway-through.

  Domain ownership verification is intentionally NOT a step here -- the
  issue item marks it optional ("for domain/DNS checks"), and this app
  doesn't have a domain-verification mechanism (TXT record challenge,
  etc.) built yet; a monitor with type='domain' or type='dns' works
  today without one, same as every other check type. Listing it as a
  checklist step would silently imply a feature that isn't real.

  Visual language: Tactical Telemetry (.claude/skills/stacks-design-
  brutalist) via partials/telemetry-head.stx. Steps render as numbered
  panel compartments; phosphor green marks COMPLETE readouts only,
  pending steps stay neutral (a not-yet-done setup step is not a fault).
-->
<script server>
const Database = require('bun:sqlite').Database
const path = require('path')
const { config } = require('@stacksjs/config')
const { Auth, sessionUser } = require('@stacksjs/auth')

const dbPath = path.resolve(process.cwd(), process.env.DB_DATABASE_PATH || 'database/stacks.sqlite')
const db = new Database(dbPath, { readonly: true })

// Auth + team resolution -- see resources/views/dashboard/monitors/
// index.stx's copy of this block for the full rationale. This page
// used to trust a client-supplied `?team_id=` query param outright.
async function resolveAuthTeam() {
  const guardName = config.auth?.default || 'api'
  const guard = config.auth?.guards?.[guardName] || {}
  const driver = guard.driver || 'token'
  const cookieName = driver === 'session' ? 'session_id' : (config.auth?.defaultTokenName || 'auth-token')

  const cookieValue = (typeof globalThis !== 'undefined' && globalThis.requestContext)
    ? globalThis.requestContext.cookie(cookieName)
    : null
  if (!cookieValue) return null

  const user = driver === 'session' ? await sessionUser(cookieValue) : await Auth.getUserFromToken(cookieValue)
  if (!user || !user.id) return null

  const membership = db.query(`
    SELECT team_id FROM team_members
    WHERE user_id = ?1 AND status = 'active'
    ORDER BY CASE WHEN role = 'owner' THEN 0 WHEN role = 'admin' THEN 1 ELSE 2 END
    LIMIT 1
  `).get(user.id)

  return { user, teamId: membership ? membership.team_id : null }
}

const AUTH = await resolveAuthTeam()
const AUTH_USER = AUTH ? AUTH.user : null
const TEAM_ID = AUTH && AUTH.teamId ? AUTH.teamId : -1
const NAV_ACTIVE = 'monitors'

const monitorCount = db.query(`SELECT COUNT(*) as c FROM monitors WHERE team_id = ?1`).get(TEAM_ID).c
const channelCount = db.query(`SELECT COUNT(*) as c FROM notification_channels WHERE team_id = ?1`).get(TEAM_ID).c
const statusPageCount = db.query(`SELECT COUNT(*) as c FROM status_pages WHERE team_id = ?1`).get(TEAM_ID).c

const steps = [
  { done: monitorCount > 0, title: 'Add your first monitor', description: 'Track uptime, SSL, DNS, and more for a URL you care about.', href: '/dashboard/monitors' },
  { done: channelCount > 0, title: 'Pick a notification channel', description: 'Slack, email, PagerDuty, or any of the other supported channels.', href: '/dashboard/settings/notifications' },
  { done: statusPageCount > 0, title: 'Create a status page', description: 'A public page your customers can check during an incident.', href: '/dashboard/status-pages' },
]
const completedCount = steps.filter((s) => s.done).length

// Display-only: zero-padded step numbers for the panel heads.
const stepsDisplay = steps.map((s, i) => ({ ...s, num: String(i + 1).padStart(2, '0') }))
const allDone = completedCount === steps.length
const generatedAt = new Date().toISOString().replace('T', ' ').slice(0, 19)
</script>

@include('../partials/telemetry-head.stx')
@include('../partials/telemetry-nav.stx')

<main class="tl-shell" style="max-width: 860px;">
  @if (!AUTH_USER)
    <div class="tl-empty" style="margin: 48px 0;">
      <span class="big">[ NO ACTIVE SESSION ]</span>
      <span class="why">Authentication required to run the setup sequence. <a href="/login" data-no-router style="color: var(--ink); text-decoration: underline;">Sign in</a>.</span>
    </div>
  @endif

  @if (AUTH_USER)
    <header class="tl-banner">
      <h1 class="tl-title">Get Online</h1>
      <div class="tl-banner-meta">
        <span>SETUP SEQUENCE {{ completedCount }} / {{ steps.length }} COMPLETE</span>
        <span class="hz">{{ allDone ? 'ALL SYSTEMS CONFIGURED' : 'CONFIGURATION INCOMPLETE' }} /// {{ generatedAt }} UTC</span>
      </div>
    </header>

    <section aria-label="Setup progress" style="margin: 24px 0;">
      <span class="tl-label">[ Sequence progress: {{ completedCount }} of {{ steps.length }} ]</span>
      <div class="tl-bars" style="height: 14px;">
        @foreach (stepsDisplay as step)
          <span class="{{ step.done ? '' : 'unknown' }}" title="STEP {{ step.num }} {{ step.done ? 'COMPLETE' : 'PENDING' }}"></span>
        @endforeach
      </div>
    </section>

    @foreach (stepsDisplay as step)
      <section class="tl-panel">
        <div class="tl-panel-head">
          <span><span class="{{ step.done ? '' : 'hz' }}">[ {{ step.num }} ]</span> {{ step.title }}</span>
          @if (step.done)
            <data class="st st-up" value="done">Complete</data>
          @endif
          @if (!step.done)
            <data class="st st-unknown" value="pending">Pending</data>
          @endif
        </div>
        <div class="tl-panel-body" style="display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap;">
          <p style="margin: 0; color: var(--dim); font-size: 12px; max-width: 60ch;">{{ step.description }}</p>
          <a href="{{ step.href }}" class="tl-btn {{ step.done ? 'ghost' : '' }}">{{ step.done ? 'Review >>' : 'Begin step >>' }}</a>
        </div>
      </section>
    @endforeach

    <footer class="tl-footnote">
      <span>CHECKLIST RE-DERIVED FROM LIVE DATA ON EVERY LOAD /// NO STORED WIZARD STATE</span>
      <span>UPTIME///STATUS © TELEMETRY CONSOLE</span>
    </footer>
  @endif
</main>
