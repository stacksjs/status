<!--
  Team settings — members list + invite form (stacksjs/status#1 Phase
  8). Same server-rendered, native-HTML-form convention as
  status-pages/index.stx, built on top of the Phase 9 TeamMember/invite
  backend (app/Models/TeamMember.ts, Actions/Teams/InviteTeamMemberAction).

  Visual language: Tactical Telemetry (.claude/skills/stacks-design-
  brutalist) via partials/telemetry-head.stx. Phosphor green marks
  ACTIVE membership readouts only; hazard red marks removals.
-->
<script server>
const Database = require('bun:sqlite').Database
const path = require('path')
const { config } = require('@stacksjs/config')
const { Auth, sessionUser } = require('@stacksjs/auth')

const dbPath = path.resolve(process.cwd(), process.env.DB_DATABASE_PATH || 'database/stacks.sqlite')
const db = new Database(dbPath, { readonly: true })

// Auth + team resolution — see resources/views/dashboard/monitors/
// index.stx's copy of this block for the full rationale. This page
// used to trust a client-supplied `?team_id=` query param outright,
// letting any signed-in user view (and, via the forms below, invite
// into / remove members from) any team by editing the URL.
async function resolveAuthTeam() {
  const guardName = config.auth?.default || 'api'
  const guard = config.auth?.guards?.[guardName] || {}
  const driver = guard.driver || 'token'
  const cookieName = driver === 'session' ? 'session_id' : (config.auth?.defaultTokenName || 'auth-token')

  const cookieValue = (typeof globalThis !== 'undefined' && globalThis.requestContext)
    ? globalThis.requestContext.cookie(cookieName)
    : null
  if (!cookieValue) return null

  const user = driver === 'session' ? await sessionUser(cookieValue) : await Auth.getUserFromToken(cookieValue)
  if (!user || !user.id) return null

  const membership = db.query(`
    SELECT team_id FROM team_members
    WHERE user_id = ?1 AND status = 'active'
    ORDER BY CASE WHEN role = 'owner' THEN 0 WHEN role = 'admin' THEN 1 ELSE 2 END
    LIMIT 1
  `).get(user.id)

  return { user, teamId: membership ? membership.team_id : null }
}

const AUTH = await resolveAuthTeam()
const AUTH_USER = AUTH ? AUTH.user : null
const TEAM_ID = AUTH && AUTH.teamId ? AUTH.teamId : -1
const NAV_ACTIVE = 'settings'

const team = db.query(`SELECT id, name FROM teams WHERE id = ?1 LIMIT 1`).get(TEAM_ID)
const members = db.query(`SELECT id, invited_email, role, status, invited_at, joined_at FROM team_members WHERE team_id = ?1 ORDER BY role ASC, invited_email ASC`).all(TEAM_ID)

// Uptime report settings (migration 0000000195). Defensive try/catch:
// migrations are applied manually in this repo, so the page must still
// render (with defaults) before the report columns exist.
let REPORT_SETTINGS = { frequency: 'none', recipients: '' }
try {
  const reportRow = db.query(`SELECT report_frequency, report_recipients FROM teams WHERE id = ?1 LIMIT 1`).get(TEAM_ID)
  if (reportRow) {
    REPORT_SETTINGS = {
      frequency: reportRow.report_frequency || 'none',
      recipients: reportRow.report_recipients || '',
    }
  }
} catch (e) {
  // Columns not migrated yet; keep defaults.
}

// Display-only helpers below this line.
const activeCount = members.filter((m) => m.status !== 'pending').length
const pendingCount = members.filter((m) => m.status === 'pending').length

function dateLabel(iso) {
  if (!iso) return '--'
  return String(iso).slice(0, 10)
}

const generatedAt = new Date().toISOString().replace('T', ' ').slice(0, 19)
</script>

@include('../partials/telemetry-head.stx')
@include('../partials/telemetry-nav.stx')

<main class="tl-shell">
  @if (!AUTH_USER)
    <div class="tl-empty" style="margin: 48px 0;">
      <span class="big">[ NO ACTIVE SESSION ]</span>
      <span class="why">Authentication required to read team roster. <a href="/login" data-no-router style="color: var(--ink); text-decoration: underline;">Sign in</a>.</span>
    </div>
  @endif

  @if (AUTH_USER)
    <header class="tl-banner">
      <h1 class="tl-title">Team</h1>
      <div class="tl-banner-meta">
        <span>{{ team ? team.name : 'TEAM #' + TEAM_ID }}</span>
        <span>{{ members.length }} OPERATOR{{ members.length === 1 ? '' : 'S' }} ON ROSTER</span>
        <span class="hz">SETTINGS /// {{ generatedAt }} UTC</span>
      </div>
    </header>

    <div class="tl-filters">
      <div class="tl-filter-group">
        <span class="lbl">Settings</span>
        <a href="/dashboard/settings/team" class="tl-chip active">Team</a>
        <a href="/dashboard/settings/notifications" class="tl-chip">Notifications</a>
        <a href="/dashboard/settings/billing" class="tl-chip">Billing</a>
      </div>
    </div>

    <dl class="tl-stats">
      <div class="tl-stat">
        <dt>[ Operators ]</dt>
        <dd><output>{{ members.length }}</output></dd>
      </div>
      <div class="tl-stat">
        <dt>[ Active ]</dt>
        <dd class="{{ activeCount > 0 ? 'ok' : '' }}"><output>{{ activeCount }}</output></dd>
      </div>
      <div class="tl-stat">
        <dt>[ Pending invites ]</dt>
        <dd><output>{{ pendingCount }}</output></dd>
      </div>
      <div class="tl-stat">
        <dt>[ Uptime reports ]</dt>
        <dd class="{{ REPORT_SETTINGS.frequency !== 'none' ? 'ok' : '' }}"><output style="font-size: 18px; text-transform: uppercase;">{{ REPORT_SETTINGS.frequency === 'none' ? 'OFF' : REPORT_SETTINGS.frequency }}</output></dd>
      </div>
    </dl>

    @if (members.length === 0)
      <div class="tl-empty" style="margin-top: 24px;">
        <span class="big">[ ROSTER EMPTY ]</span>
        <span class="why">No operators registered on this team. Dispatch an invite below.</span>
      </div>
    @endif

    @if (members.length > 0)
      <section class="tl-table" style="margin-top: 24px;" aria-label="Team roster">
        <div class="tl-thead" style="grid-template-columns: minmax(0, 1.6fr) 110px 130px 120px 110px;">
          <span class="tl-cell">Operator</span>
          <span class="tl-cell">Role</span>
          <span class="tl-cell">Status</span>
          <span class="tl-cell num">Joined</span>
          <span class="tl-cell num">Action</span>
        </div>
        @foreach (members as member)
          <div class="tl-row" style="grid-template-columns: minmax(0, 1.6fr) 110px 130px 120px 110px; {{ member.status === 'pending' ? 'opacity: 0.6;' : '' }}">
            <span class="tl-cell tl-ellipsis" style="font-weight: 700;">{{ member.invited_email }}</span>
            <span class="tl-cell sub" style="text-transform: uppercase; letter-spacing: 0.08em; {{ member.role === 'owner' ? 'color: var(--ink); font-weight: 700;' : '' }}">{{ member.role }}</span>
            <span class="tl-cell">
              @if (member.status === 'pending')
                <data class="st st-unknown" value="pending">PENDING</data>
              @endif
              @if (member.status !== 'pending')
                <data class="st st-up" value="active">ACTIVE</data>
              @endif
            </span>
            <span class="tl-cell num sub"><time>{{ dateLabel(member.joined_at || member.invited_at) }}</time></span>
            <span class="tl-cell num">
              <form method="POST" action="/api/team-forms/{{ member.id }}/remove">
                <input type="hidden" name="team_id" value="{{ TEAM_ID }}" />
                <button type="submit" class="tl-btn danger ghost" style="background: transparent; color: var(--hazard); border-color: var(--line); padding: 5px 10px; font-size: 10px;">Remove</button>
              </form>
            </span>
          </div>
        @endforeach
      </section>
    @endif

    <section class="tl-panel" aria-label="Invite operator">
      <div class="tl-panel-head">
        <span>[ INVITE OPERATOR ]</span>
        <span style="color: var(--faint);">DISPATCHED VIA EMAIL TOKEN</span>
      </div>
      <div class="tl-panel-body">
        <form method="POST" action="/api/team-forms/{{ TEAM_ID }}/invite" style="display: flex; align-items: flex-end; gap: 12px; flex-wrap: wrap;">
          <div style="flex: 1 1 260px; min-width: 200px;">
            <label class="tl-label">Email</label>
            <input type="email" name="email" required class="tl-input" placeholder="operator@company.com" />
          </div>
          <div style="flex: 0 0 160px;">
            <label class="tl-label">Role</label>
            <select name="role" class="tl-select">
              <option value="member">Member</option>
              <option value="admin">Admin</option>
              <option value="owner">Owner</option>
            </select>
          </div>
          <button type="submit" class="tl-btn">Invite</button>
        </form>
        <p style="margin: 12px 0 0; font-size: 10px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--faint);">Invites are emailed with their acceptance token. Accepting still happens via the API until dashboard sign-in lands.</p>
      </div>
    </section>

    <section class="tl-panel" aria-label="Uptime reports">
      <div class="tl-panel-head">
        <span>[ UPTIME REPORTS ]</span>
        <span style="{{ REPORT_SETTINGS.frequency !== 'none' ? 'color: var(--phosphor);' : 'color: var(--faint);' }}">{{ REPORT_SETTINGS.frequency === 'none' ? 'DISPATCH OFF' : 'DISPATCH ' + REPORT_SETTINGS.frequency.toUpperCase() }}</span>
      </div>
      <div class="tl-panel-body">
        <form method="POST" action="/api/team-forms/{{ TEAM_ID }}/report-settings" style="display: flex; align-items: flex-end; gap: 12px; flex-wrap: wrap;">
          <div style="flex: 0 0 160px;">
            <label class="tl-label">Frequency</label>
            <select name="report_frequency" class="tl-select">
              <option value="none" {{ REPORT_SETTINGS.frequency === 'none' ? 'selected' : '' }}>Off</option>
              <option value="weekly" {{ REPORT_SETTINGS.frequency === 'weekly' ? 'selected' : '' }}>Weekly</option>
              <option value="monthly" {{ REPORT_SETTINGS.frequency === 'monthly' ? 'selected' : '' }}>Monthly</option>
            </select>
          </div>
          <div style="flex: 1 1 280px; min-width: 220px;">
            <label class="tl-label">Recipients</label>
            <input type="text" name="report_recipients" value="{{ REPORT_SETTINGS.recipients }}" class="tl-input" placeholder="owner@company.com, client@company.com" />
          </div>
          <button type="submit" class="tl-btn">Save</button>
        </form>
        <p style="margin: 12px 0 0; font-size: 10px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--faint);">Leave empty to send to the team owner. A client-ready summary of uptime, response times, incidents, and crawl findings is emailed each period.</p>
      </div>
    </section>

    <footer class="tl-footnote">
      <span>ROSTER {{ members.length }} / PENDING {{ pendingCount }}</span>
      <span>UPTIME///STATUS © TELEMETRY CONSOLE</span>
    </footer>
  @endif
</main>
