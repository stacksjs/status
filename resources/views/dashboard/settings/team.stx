<!--
  Team settings — members list + invite form (stacksjs/status#1 Phase
  8). Same server-rendered, native-HTML-form convention as
  status-pages/index.stx, built on top of the Phase 9 TeamMember/invite
  backend (app/Models/TeamMember.ts, Actions/Teams/InviteTeamMemberAction).

  Visual language: the marketing site's design system (emerald accent,
  Space Grotesk display, light + dark) via partials/app-head.stx +
  app-nav.stx, so the app reads as the same product as the site.
-->
<script server>
const { resolveTeamContext } = require('@stacksjs/auth')
// Dialect-agnostic DB access (sqlite self-hosted / networked Postgres hosted).
const { db } = require('@stacksjs/database')


// Auth + team resolution — see resources/views/dashboard/monitors/
// index.stx's copy of this block for the full rationale. This page
// used to trust a client-supplied `?team_id=` query param outright,
// letting any signed-in user view (and, via the forms below, invite
// into / remove members from) any team by editing the URL.
// Auth + active-team resolution via @stacksjs/auth's resolveTeamContext,
// which honors the workspace-switcher cookie (see dashboard/index.stx for the
// full note). allowAnyTeam lets a super-admin switch to / see any team;
// unpinned, a super-admin still sees every team merged.
const TEAM_CTX = await resolveTeamContext(
  { cookies: { get: n => ((typeof globalThis !== 'undefined' && globalThis.requestContext) ? globalThis.requestContext.cookie(n) : null) } },
  { allowAnyTeam: u => !!(u && u.is_super_admin) },
)
const AUTH_USER = TEAM_CTX.user
const TEAM_ID = TEAM_CTX.teamId ?? -1
const IS_SUPER = !!(AUTH_USER && AUTH_USER.is_super_admin)
const SWITCHABLE_TEAMS = TEAM_CTX.teams
const SEE_ALL = IS_SUPER && !TEAM_CTX.activeTeamId
const ACTIVE_TEAM_NAME = (TEAM_CTX.teams.find(t => t.id === TEAM_ID) || {}).name || ''
const teamScope = qb => SEE_ALL ? qb : qb.where('team_id', '=', TEAM_ID)
const NAV_ACTIVE = 'settings'

const team = (await db.selectFrom('teams').where('id', '=', TEAM_ID).limit(1).execute())[0]
const members = await db.selectFrom('team_members').where('team_id', '=', TEAM_ID).orderBy('role', 'asc').orderBy('invited_email', 'asc').execute()

// Uptime report settings (migration 0000000195). Defensive try/catch:
// migrations are applied manually in this repo, so the page must still
// render (with defaults) before the report columns exist.
let REPORT_SETTINGS = { frequency: 'none', recipients: '' }
try {
  const reportRow = (await db.selectFrom('teams').where('id', '=', TEAM_ID).limit(1).execute())[0]
  if (reportRow) {
    REPORT_SETTINGS = {
      frequency: reportRow.report_frequency || 'none',
      recipients: reportRow.report_recipients || '',
    }
  }
} catch (e) {
  // Columns not migrated yet; keep defaults.
}

// Display-only helpers below this line.
const activeCount = members.filter((m) => m.status !== 'pending').length
const pendingCount = members.filter((m) => m.status === 'pending').length

function dateLabel(iso) {
  if (!iso) return '--'
  return String(iso).slice(0, 10)
}

function reportFrequencyLabel(freq) {
  if (freq === 'monthly') return 'Monthly'
  if (freq === 'weekly') return 'Weekly'
  return 'Off'
}

const generatedAt = new Date().toISOString().replace('T', ' ').slice(0, 19)

// Real document title + noindex for the app surface (the serve wrapper
// otherwise stamps every fragment 'stx App'). useHead is the sanctioned
// per-page head hook for fragment views.
useHead({ title: 'Team settings \u00b7 UptimeStatus', meta: [{ name: 'robots', content: 'noindex' }] })
</script>

@include('../partials/app-head.stx')
@include('../partials/app-nav.stx')

<main class="app-shell">
  @if (!AUTH_USER)
    <div class="empty" style="margin: 3rem 0;">
      <h3>Sign in required</h3>
      <p>You need an authenticated session to view your team.</p>
      <div class="actions"><a class="button primary" href="/login" data-no-router>Sign in</a></div>
    </div>
  @endif

  @if (AUTH_USER)
    <header class="page-head">
      <div>
        <h1>Team</h1>
        <p class="meta">{{ team ? team.name : 'Team #' + TEAM_ID }} &middot; {{ members.length }} member{{ members.length === 1 ? '' : 's' }}</p>
      </div>
    </header>

    <div class="filter-bar">
      <div class="filter-group">
        <span class="lbl">Settings</span>
        <a href="/dashboard/settings/team" class="chip active">Team</a>
        <a href="/dashboard/settings/notifications" class="chip">Notifications</a>
        <a href="/dashboard/settings/security" class="chip">Security</a>
        <a href="/dashboard/settings/cloud" class="chip">Cloud</a>
        <a href="/dashboard/settings/billing" class="chip">Billing</a>
      </div>
    </div>

    @if (members.length === 0)
      <div class="empty">
        <h3>No members yet</h3>
        <p>Nobody is on this team roster. Invite a teammate below.</p>
      </div>
    @endif

    @if (members.length > 0)
      <section class="card scroll-x" aria-label="Team roster">
        <div class="card-head">
          <h2>Members</h2>
          <span class="sub">{{ activeCount }} active &middot; {{ pendingCount }} pending</span>
        </div>
        <div class="rows">
          <div class="trow thead" style="grid-template-columns: minmax(0, 1.6fr) 110px 130px 110px 110px;">
            <span class="tcell">Member</span>
            <span class="tcell">Role</span>
            <span class="tcell">Status</span>
            <span class="tcell num">Joined</span>
            <span class="tcell num">Remove</span>
          </div>
          @foreach (members as member)
            <div class="trow" style="grid-template-columns: minmax(0, 1.6fr) 110px 130px 110px 110px;">
              <span class="tcell ellipsis name">{{ member.invited_email }}</span>
              <span class="tcell sub">{{ member.role }}</span>
              <span class="tcell">
                @if (member.status === 'pending')
                  <data class="pill pill-unknown" value="pending"><span class="dot"></span>Pending</data>
                @endif
                @if (member.status !== 'pending')
                  <data class="pill pill-up" value="active"><span class="dot"></span>Active</data>
                @endif
              </span>
              <span class="tcell num"><time>{{ dateLabel(member.joined_at || member.invited_at) }}</time></span>
              <span class="tcell num">
                <form method="POST" action="/api/team-forms/{{ member.id }}/remove">
                  <input type="hidden" name="team_id" value="{{ TEAM_ID }}" />
                  <button type="submit" class="button danger sm">Remove</button>
                </form>
              </span>
            </div>
          @endforeach
        </div>
      </section>
    @endif

    <section class="card" aria-label="Invite a teammate" style="margin-top: 1.25rem;">
      <div class="card-head">
        <h2>Invite a teammate</h2>
        <span class="sub">Sent by email</span>
      </div>
      <div class="card-body">
        <form method="POST" action="/api/team-forms/{{ TEAM_ID }}/invite">
          <div class="form-row">
            <div class="field">
              <label>Email</label>
              <input type="email" name="email" required class="input" placeholder="teammate@company.com" />
            </div>
            <div class="field">
              <label>Role</label>
              <select name="role" class="select">
                <option value="member">Member</option>
                <option value="admin">Admin</option>
                <option value="owner">Owner</option>
              </select>
            </div>
          </div>
          <button type="submit" class="button primary">Invite</button>
          <div class="field" style="margin: 0.75rem 0 0;">
            <p class="help">Invites are emailed with their acceptance token. Accepting still happens via the API until dashboard sign-in lands.</p>
          </div>
        </form>
      </div>
    </section>

    <section class="card" aria-label="Uptime reports">
      <div class="card-head">
        <h2>Uptime reports</h2>
        <span class="sub">{{ reportFrequencyLabel(REPORT_SETTINGS.frequency) }}</span>
      </div>
      <div class="card-body">
        <form method="POST" action="/api/team-forms/{{ TEAM_ID }}/report-settings">
          <div class="form-row">
            <div class="field">
              <label>Frequency</label>
              <select name="report_frequency" class="select">
                <option value="none" {{ REPORT_SETTINGS.frequency === 'none' ? 'selected' : '' }}>Off</option>
                <option value="weekly" {{ REPORT_SETTINGS.frequency === 'weekly' ? 'selected' : '' }}>Weekly</option>
                <option value="monthly" {{ REPORT_SETTINGS.frequency === 'monthly' ? 'selected' : '' }}>Monthly</option>
              </select>
            </div>
            <div class="field">
              <label>Recipients</label>
              <input type="text" name="report_recipients" value="{{ REPORT_SETTINGS.recipients }}" class="input" placeholder="owner@company.com, client@company.com" />
              <p class="help">Leave empty to send to the team owner.</p>
            </div>
          </div>
          <button type="submit" class="button primary">Save</button>
          <div class="field" style="margin: 0.75rem 0 0;">
            <p class="help">A client-ready summary of uptime, response times, incidents, and crawl findings is emailed each period.</p>
          </div>
        </form>
      </div>
    </section>

    <footer class="app-foot">
      <span>{{ members.length }} member{{ members.length === 1 ? '' : 's' }} &middot; {{ pendingCount }} pending</span>
      <span>Updated {{ generatedAt }} UTC</span>
    </footer>
  @endif
</main>
