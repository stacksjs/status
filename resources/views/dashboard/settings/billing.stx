<!--
  Billing settings — current plan, usage vs limits, upgrade/cancel
  (stacksjs/status#1 Phase 9). Same server-rendered, native-HTML-form
  convention as team.stx. TEAM_ID is derived from the authenticated
  session (see the auth+team resolution block below), not a client
  query param.

  Visual language: the marketing site's design system (emerald accent,
  Space Grotesk display, light + dark) via partials/app-head.stx +
  app-nav.stx, so the app reads as the same product as the site.
-->
<script server>
const { config } = require('@stacksjs/config')
const { Auth, sessionUser } = require('@stacksjs/auth')
// Dialect-agnostic DB access (sqlite self-hosted / networked Postgres hosted).
const { db } = require('@stacksjs/database')

const ROLE_PRIORITY = { owner: 0, admin: 1 }

// Auth + team resolution — see resources/views/dashboard/monitors/
// index.stx's copy of this block for the full rationale. This page
// used to trust a client-supplied `?team_id=` query param outright,
// letting any signed-in user view (and start/cancel checkout for) any
// team's billing by editing the URL.
async function resolveAuthTeam() {
  const guardName = config.auth?.default || 'api'
  const guard = config.auth?.guards?.[guardName] || {}
  const driver = guard.driver || 'token'
  const cookieName = driver === 'session' ? 'session_id' : (config.auth?.defaultTokenName || 'auth-token')

  const cookieValue = (typeof globalThis !== 'undefined' && globalThis.requestContext)
    ? globalThis.requestContext.cookie(cookieName)
    : null
  if (!cookieValue) return null

  const user = driver === 'session' ? await sessionUser(cookieValue) : await Auth.getUserFromToken(cookieValue)
  if (!user || !user.id) return null

  const memberships = await db.selectFrom('team_members')
    .where('user_id', '=', user.id).where('status', '=', 'active').execute()
  memberships.sort((a, b) => (ROLE_PRIORITY[a.role] ?? 2) - (ROLE_PRIORITY[b.role] ?? 2))
  const membership = memberships[0]

  return { user, teamId: membership ? membership.team_id : null }
}

const AUTH = await resolveAuthTeam()
const AUTH_USER = AUTH ? AUTH.user : null
const TEAM_ID = AUTH && AUTH.teamId ? AUTH.teamId : -1
const NAV_ACTIVE = 'settings'

const query = (typeof __stxServeSearch !== 'undefined' && __stxServeSearch) ? new URLSearchParams(__stxServeSearch) : new URLSearchParams()
const CHECKOUT_RESULT = query.get('checkout')
const CANCELLED = query.get('cancelled')
const ERROR = query.get('error')

const PLAN_LIMITS = {
  free: { monitors: 5, statusPages: 1, checkIntervalFloorSeconds: 300 },
  pro: { monitors: 100, statusPages: 10, checkIntervalFloorSeconds: 30 },
  'self-hosted': { monitors: Infinity, statusPages: Infinity, checkIntervalFloorSeconds: 10 },
}
const PAID_PLAN_PRICE_USD = 9

// Self-hosted installs leave Stripe unconfigured; billing (and therefore
// plan tiering) is only live when a secret key is present. Mirrors
// billingEnabled() in config/plans.ts — kept as a local check because this
// server script talks to the DB directly rather than importing config/plans.
const BILLING_ENABLED = Boolean(process.env.STRIPE_SECRET_KEY)

const team = (await db.selectFrom('teams').where('id', '=', TEAM_ID).limit(1).execute())[0]
const owner = (await db.selectFrom('team_members').where('team_id', '=', TEAM_ID).where('role', '=', 'owner').where('status', '=', 'active').limit(1).execute())[0]

let subscription = null
if (BILLING_ENABLED && owner && owner.user_id) {
  subscription = (await db.selectFrom('subscriptions').where('user_id', '=', owner.user_id).orderByDesc('id').limit(1).execute())[0]
}

const isActivePaid = subscription && subscription.plan === 'pro' && subscription.provider_status === 'active'
const currentPlan = !BILLING_ENABLED ? 'self-hosted' : (isActivePaid ? 'pro' : 'free')
const limits = PLAN_LIMITS[currentPlan]

const monitorCount = await db.selectFrom('monitors').where('team_id', '=', TEAM_ID).count()
const statusPageCount = await db.selectFrom('status_pages').where('team_id', '=', TEAM_ID).count()

function usagePct(used, limit) {
  if (!limit || !isFinite(limit)) return 0
  return Math.min(100, Math.round((used / limit) * 100))
}
function limitLabel(limit) {
  return isFinite(limit) ? limit : '∞'
}

const planLabel = currentPlan === 'pro' ? 'Pro' : currentPlan === 'self-hosted' ? 'Self-hosted' : 'Free'

const generatedAt = new Date().toISOString().replace('T', ' ').slice(0, 19)

// Real document title + noindex for the app surface (the serve wrapper
// otherwise stamps every fragment 'stx App'). useHead is the sanctioned
// per-page head hook for fragment views.
useHead({ title: 'Billing \u00b7 UptimeStatus', meta: [{ name: 'robots', content: 'noindex' }] })
</script>

@include('../partials/app-head.stx')
@include('../partials/app-nav.stx')

<main class="app-shell">
  @if (!AUTH_USER)
    <div class="empty" style="margin: 3rem 0;">
      <h3>Sign in required</h3>
      <p>You need an authenticated session to view this page.</p>
      <div class="actions"><a class="button primary" href="/login" data-no-router>Sign in</a></div>
    </div>
  @endif

  @if (AUTH_USER)
    <header class="page-head">
      <div>
        <h1>Billing</h1>
        <p class="meta">{{ team ? team.name : 'Team #' + TEAM_ID }} &middot; {{ planLabel }} plan</p>
      </div>
    </header>

    <div class="filter-bar">
      <div class="filter-group">
        <span class="lbl">Settings</span>
        <a href="/dashboard/settings/team" class="chip">Team</a>
        <a href="/dashboard/settings/notifications" class="chip">Notifications</a>
        <a href="/dashboard/settings/cloud" class="chip">Cloud</a>
        <a href="/dashboard/settings/billing" class="chip active">Billing</a>
      </div>
    </div>

    @if (CHECKOUT_RESULT === 'success')
      <div class="flash">Checkout complete. Your plan will update within a few seconds once Stripe's webhook lands.</div>
    @endif
    @if (CHECKOUT_RESULT === 'cancelled')
      <div class="flash">Checkout was cancelled. No changes were made.</div>
    @endif
    @if (CANCELLED === '1')
      <div class="flash">Subscription cancelled. You'll stay on Pro until the current billing period ends, then drop to Free.</div>
    @endif
    @if (ERROR)
      <div class="flash error">{{ ERROR === 'no_owner' ? 'This team has no active owner to bill.' : ERROR === 'no_active_subscription' ? 'No active subscription to cancel.' : ERROR }}</div>
    @endif

    <section class="card" aria-label="Current plan">
      <div class="card-head">
        <h2>Current plan</h2>
        <span class="sub">{{ currentPlan === 'self-hosted' ? 'No limits' : (currentPlan === 'pro' ? '$' + PAID_PLAN_PRICE_USD + '/mo' : '$0/mo') }}</span>
      </div>
      <div class="card-body">
        <p style="margin: 0 0 1.15rem; font-family: var(--font-display); font-size: 1.35rem; font-weight: 600;">{{ planLabel }}</p>

        <div style="margin-bottom: 0.9rem;">
          <div style="display: flex; justify-content: space-between; gap: 1rem; margin-bottom: 0.4rem; color: var(--muted); font-size: 0.8rem;">
            <span>Monitors</span>
            <span class="mono">{{ monitorCount }} / {{ limitLabel(limits.monitors) }}</span>
          </div>
          <div style="height: 6px; border-radius: 999px; background: var(--surface-2); overflow: hidden;">
            <div style="height: 100%; border-radius: 999px; background: var(--accent); width: {{ usagePct(monitorCount, limits.monitors) }}%;"></div>
          </div>
        </div>

        <div style="margin-bottom: 0.9rem;">
          <div style="display: flex; justify-content: space-between; gap: 1rem; margin-bottom: 0.4rem; color: var(--muted); font-size: 0.8rem;">
            <span>Status pages</span>
            <span class="mono">{{ statusPageCount }} / {{ limitLabel(limits.statusPages) }}</span>
          </div>
          <div style="height: 6px; border-radius: 999px; background: var(--surface-2); overflow: hidden;">
            <div style="height: 100%; border-radius: 999px; background: var(--accent); width: {{ usagePct(statusPageCount, limits.statusPages) }}%;"></div>
          </div>
        </div>

        <p style="margin: 0; color: var(--muted); font-size: 0.8rem;">Minimum check interval: <span class="mono">{{ limits.checkIntervalFloorSeconds }}s</span></p>
      </div>
    </section>

    @if (currentPlan === 'pro')
      <section class="card" aria-label="Manage subscription">
        <div class="card-head">
          <h2>Manage subscription</h2>
        </div>
        <div class="card-body">
          <p style="margin: 0 0 1rem; color: var(--muted); font-size: 0.9rem;">
            @if (subscription && subscription.ends_at)
              Cancels at the end of the current billing period.
            @else
              Renews automatically each month.
            @endif
          </p>
          <form method="POST" action="/api/billing-forms/cancel" onsubmit="return confirm('Cancel your Pro subscription? You will drop to the Free plan at the end of the current billing period.')">
            <input type="hidden" name="team_id" value="{{ TEAM_ID }}" />
            <button type="submit" class="button danger">Cancel subscription</button>
          </form>
        </div>
      </section>
    @endif
    @if (currentPlan === 'free')
      <section class="card" aria-label="Upgrade to Pro">
        <div class="card-head">
          <h2>Upgrade to Pro</h2>
          <span class="sub">${{ PAID_PLAN_PRICE_USD }}/mo</span>
        </div>
        <div class="card-body">
          <ul style="margin: 0 0 1.15rem; padding-left: 1.1rem; color: var(--muted); font-size: 0.9rem; line-height: 1.7;">
            <li>{{ PLAN_LIMITS.pro.monitors }} monitors (vs {{ PLAN_LIMITS.free.monitors }} on Free)</li>
            <li>{{ PLAN_LIMITS.pro.statusPages }} status pages (vs {{ PLAN_LIMITS.free.statusPages }} on Free)</li>
            <li>Checks as often as every {{ PLAN_LIMITS.pro.checkIntervalFloorSeconds }}s</li>
          </ul>
          <form method="POST" action="/api/billing-forms/checkout">
            <input type="hidden" name="team_id" value="{{ TEAM_ID }}" />
            <button type="submit" class="button primary">Upgrade for ${{ PAID_PLAN_PRICE_USD }}/mo</button>
          </form>
        </div>
      </section>
    @endif
    @if (currentPlan === 'self-hosted')
      <section class="card" aria-label="Self-hosted">
        <div class="card-head">
          <h2>Self-hosted</h2>
        </div>
        <div class="card-body">
          <p style="margin: 0; color: var(--muted); font-size: 0.9rem;">
            This is your own install, so there are no plan limits. Monitor as much as your
            server can handle. Billing is inactive because no payment provider is configured.
          </p>
        </div>
      </section>
    @endif

    <footer class="app-foot">
      <span>{{ monitorCount }} / {{ limitLabel(limits.monitors) }} monitors &middot; {{ statusPageCount }} / {{ limitLabel(limits.statusPages) }} status pages</span>
      <span>Updated {{ generatedAt }} UTC</span>
    </footer>
  @endif
</main>
