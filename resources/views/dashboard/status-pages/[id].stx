<!--
  Status page builder/editor — dashboard page (stacksjs/status#1 Phase
  8). Native HTML forms (no client JS) posting to plain-POST dashboard
  actions — see Actions/StatusPages/UpdateStatusPageAction for why.

  Visual language: Tactical Telemetry (.claude/skills/stacks-design-
  brutalist) via partials/telemetry-head.stx. The single settings form
  spans the [ IDENTITY ] and [ ACCESS CONTROL ] compartments — one
  <form>, unchanged method/action/fields, two visual panels.
-->
<script server>
const { config } = require('@stacksjs/config')
const { Auth, sessionUser } = require('@stacksjs/auth')
// Dialect-agnostic DB access (sqlite self-hosted / networked Postgres hosted).
const { db } = require('@stacksjs/database')

const ROLE_PRIORITY = { owner: 0, admin: 1 }

// Auth + team resolution — see resources/views/dashboard/monitors/
// index.stx's copy of this block for the full rationale. Resolving to
// `TEAM_ID = -1` on any auth failure means the query below naturally
// returns no rows, reusing the existing "not found" state. This query
// previously had NO team check at all (just `WHERE id = ?1`) — any
// visitor could view/edit any team's status page by guessing its id.
async function resolveAuthTeam() {
  const guardName = config.auth?.default || 'api'
  const guard = config.auth?.guards?.[guardName] || {}
  const driver = guard.driver || 'token'
  const cookieName = driver === 'session' ? 'session_id' : (config.auth?.defaultTokenName || 'auth-token')

  const cookieValue = (typeof globalThis !== 'undefined' && globalThis.requestContext)
    ? globalThis.requestContext.cookie(cookieName)
    : null
  if (!cookieValue) return null

  const user = driver === 'session' ? await sessionUser(cookieValue) : await Auth.getUserFromToken(cookieValue)
  if (!user || !user.id) return null

  const memberships = await db.selectFrom('team_members')
    .where('user_id', '=', user.id).where('status', '=', 'active').execute()
  memberships.sort((a, b) => (ROLE_PRIORITY[a.role] ?? 2) - (ROLE_PRIORITY[b.role] ?? 2))
  const membership = memberships[0]

  return { user, teamId: membership ? membership.team_id : null }
}

const AUTH = await resolveAuthTeam()
const AUTH_USER = AUTH ? AUTH.user : null
const TEAM_ID = AUTH && AUTH.teamId ? AUTH.teamId : -1
const NAV_ACTIVE = 'status-pages'
const pageId = (typeof id !== 'undefined' && id) ? Number(id) : 0
const statusPage = pageId
  ? (await db.selectFrom('status_pages').where('id', '=', pageId).where('team_id', '=', TEAM_ID).limit(1).execute())[0] || null
  : null

// Assigned monitors: the pivot rows joined back to their monitors in JS
// (portable, and inner-join semantics preserved — a pivot whose monitor
// was deleted drops out via the null filter).
let assignedMonitors = []
if (statusPage) {
  const pivots = await db.selectFrom('status_page_monitors').where('status_page_id', '=', statusPage.id).execute()
  const pivotMonIds = pivots.map(p => p.monitor_id)
  const pivotMons = pivotMonIds.length ? await db.selectFrom('monitors').whereIn('id', pivotMonIds).execute() : []
  const monById = new Map(pivotMons.map(m => [m.id, m]))
  assignedMonitors = pivots
    .map((p) => {
      const m = monById.get(p.monitor_id)
      return m ? { pivot_id: p.id, monitor_id: m.id, name: m.name, type: m.type, status: m.status, display_name: p.display_name, display_order: p.display_order } : null
    })
    .filter(Boolean)
    .sort((a, b) => (a.display_order - b.display_order) || String(a.name).localeCompare(String(b.name)))
}

const assignedIds = assignedMonitors.map((m) => m.monitor_id)

// Available = the team's other monitors not already assigned to this page.
let availableMonitors = []
if (statusPage) {
  const teamMons = await db.selectFrom('monitors').where('team_id', '=', TEAM_ID).execute()
  const assignedSet = new Set(assignedIds)
  availableMonitors = teamMons.filter(m => !assignedSet.has(m.id)).sort((a, b) => String(a.name).localeCompare(String(b.name)))
}

const componentGroups = statusPage
  ? await db.selectFrom('status_page_component_groups').where('status_page_id', '=', statusPage.id).orderBy('display_order', 'asc').orderBy('name', 'asc').execute()
  : []

// Maintenance windows touching any assigned monitor — resolve the pivot
// links to distinct window ids, then fetch the newest 10.
let maintenanceWindows = []
if (statusPage && assignedIds.length > 0) {
  const links = await db.selectFrom('maintenance_window_monitors').whereIn('monitor_id', assignedIds).execute()
  const winIds = [...new Set(links.map(l => l.maintenance_window_id))]
  if (winIds.length) {
    const wins = await db.selectFrom('maintenance_windows').whereIn('id', winIds).orderBy('starts_at', 'desc').limit(10).execute()
    maintenanceWindows = wins.map(w => ({ id: w.id, title: w.title, status: w.status, starts_at: w.starts_at, ends_at: w.ends_at }))
  }
}

function formatDate(iso) {
  if (!iso) return '--'
  const d = new Date(iso)
  if (isNaN(d.getTime())) return '--'
  return d.toLocaleString('en-US', { month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' })
}

// Display-only helpers below: none of these touch queries or auth.
function stClass(status) {
  if (status === 'up') return 'st st-up'
  if (status === 'degraded') return 'st st-degraded'
  if (status === 'down') return 'st st-down'
  return 'st st-unknown'
}

function stLabel(status) {
  if (status === 'up') return 'UP'
  if (status === 'degraded') return 'DEGRADED'
  if (status === 'down') return 'DOWN'
  return 'UNKNOWN'
}

function mwClass(status) {
  if (status === 'active') return 'st st-degraded'
  if (status === 'scheduled') return 'st st-unknown'
  return 'st st-unknown'
}

const generatedAt = new Date().toISOString().replace('T', ' ').slice(0, 19)
</script>

@include('../partials/telemetry-head.stx')
@include('../partials/telemetry-nav.stx')

<style>
  .tl-form-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 16px;
  }
  .tl-attach-row {
    display: flex;
    align-items: stretch;
    gap: 8px;
  }
  .tl-attach-row .tl-select { flex: 1 1 auto; width: auto; }
  .tl-btn.sm { padding: 5px 10px; font-size: 10px; }
</style>

<main class="tl-shell">
  @if (!statusPage)
    <div class="tl-empty" style="margin: 48px 0;">
      <span class="big">[ NO SIGNAL ]</span>
      <span class="why">Status page not found for this team, or no active session. <a href="/dashboard/status-pages" style="color: var(--ink); text-decoration: underline;">Back to status pages</a>.</span>
    </div>
  @endif

  @if (statusPage)
    <header class="tl-banner">
      <h1 class="tl-title">{{ statusPage.title }}</h1>
      <div class="tl-banner-meta">
        <span><a href="/dashboard/status-pages" style="text-decoration: underline;">[ ALL CHANNELS ]</a></span>
        <span>PUBLIC UPLINK <a href="/status/{{ statusPage.slug }}" target="_blank" data-no-router style="color: var(--ink); text-decoration: underline;"><samp>/status/{{ statusPage.slug }}</samp></a></span>
        @if (statusPage.custom_domain)
          <span>DOMAIN <samp>{{ statusPage.custom_domain }}</samp></span>
        @endif
        <span class="hz">CHANNEL #{{ statusPage.id }} /// {{ generatedAt }} UTC</span>
      </div>
    </header>

    <dl class="tl-stats">
      <div class="tl-stat">
        <dt>[ Units attached ]</dt>
        <dd class="{{ assignedMonitors.length > 0 ? 'ok' : '' }}"><output>{{ assignedMonitors.length }}</output></dd>
      </div>
      <div class="tl-stat">
        <dt>[ Units available ]</dt>
        <dd><output>{{ availableMonitors.length }}</output></dd>
      </div>
      <div class="tl-stat">
        <dt>[ Component groups ]</dt>
        <dd><output>{{ componentGroups.length }}</output></dd>
      </div>
      <div class="tl-stat">
        <dt>[ Maintenance windows ]</dt>
        <dd><output>{{ maintenanceWindows.length }}</output></dd>
      </div>
      <div class="tl-stat">
        <dt>[ Access mode ]</dt>
        <dd><small style="font-size: 14px; font-weight: 700; letter-spacing: 0.08em; color: var(--ink);">{{ (statusPage.access_type || 'public').replace('_', ' ').toUpperCase() }}</small></dd>
      </div>
    </dl>

    <form method="POST" action="/api/status-page-forms/{{ statusPage.id }}/update">
      <section class="tl-panel" aria-label="Identity">
        <div class="tl-panel-head">
          <span>[ IDENTITY ]</span>
          <span class="hz">CHANNEL CALLSIGN</span>
        </div>
        <div class="tl-panel-body">
          <div class="tl-form-grid">
            <div>
              <label class="tl-label" for="sp-title">Title</label>
              <input id="sp-title" type="text" name="title" value="{{ statusPage.title }}" required class="tl-input" />
            </div>
            <div>
              <label class="tl-label" for="sp-domain">Custom domain</label>
              <input id="sp-domain" type="text" name="custom_domain" value="{{ statusPage.custom_domain }}" placeholder="status.yourcompany.com" class="tl-input" />
              <span class="tl-label" style="margin: 6px 0 0;">Slug is fixed at creation: <samp>/status/{{ statusPage.slug }}</samp></span>
            </div>
          </div>
        </div>
      </section>

      <section class="tl-panel" aria-label="Access control">
        <div class="tl-panel-head">
          <span>[ ACCESS CONTROL ]</span>
          <span class="hz">WHO READS THE FEED</span>
        </div>
        <div class="tl-panel-body">
          <div class="tl-form-grid" style="margin-bottom: 16px;">
            <div>
              <label class="tl-label" for="sp-access">Access</label>
              <select id="sp-access" name="access_type" class="tl-select">
                <option value="public" {{ statusPage.access_type === 'public' ? 'selected' : '' }}>PUBLIC</option>
                <option value="password" {{ statusPage.access_type === 'password' ? 'selected' : '' }}>PASSWORD PROTECTED</option>
                <option value="email_domain" {{ statusPage.access_type === 'email_domain' ? 'selected' : '' }}>EMAIL-DOMAIN RESTRICTED</option>
                <option value="ip_allowlist" {{ statusPage.access_type === 'ip_allowlist' ? 'selected' : '' }}>IP ALLOWLISTED</option>
              </select>
            </div>
          </div>
          <button type="submit" class="tl-btn">Save channel</button>
        </div>
      </section>
    </form>

    <section class="tl-panel" aria-label="Monitors on this page">
      <div class="tl-panel-head">
        <span>[ COMPONENTS / MONITORS ]</span>
        <span class="hz">{{ assignedMonitors.length }} UNIT{{ assignedMonitors.length === 1 ? '' : 'S' }} ON FEED</span>
      </div>
      <div class="tl-panel-body">
        @if (assignedMonitors.length === 0)
          <div class="tl-empty" style="padding: 32px 16px; margin-bottom: 16px;">
            <span class="big">[ FEED EMPTY ]</span>
            <span class="why">No monitors attached. This channel broadcasts nothing until a unit is added below.</span>
          </div>
        @endif

        @if (assignedMonitors.length > 0)
          <div class="tl-table" style="margin-bottom: 16px;">
            <div class="tl-thead" style="grid-template-columns: 120px minmax(0, 1.4fr) 130px 100px;">
              <span class="tl-cell">Status</span>
              <span class="tl-cell">Unit</span>
              <span class="tl-cell">Type</span>
              <span class="tl-cell num">Action</span>
            </div>
            @foreach (assignedMonitors as monitor)
              <div class="tl-row" style="grid-template-columns: 120px minmax(0, 1.4fr) 130px 100px;">
                <span class="tl-cell"><data class="{{ stClass(monitor.status) }}" value="{{ monitor.status }}">{{ stLabel(monitor.status) }}</data></span>
                <span class="tl-cell tl-ellipsis" style="font-weight: 700;">{{ monitor.display_name || monitor.name }}</span>
                <span class="tl-cell sub" style="text-transform: uppercase; letter-spacing: 0.08em;">{{ monitor.type.replace('_', ' ') }}</span>
                <span class="tl-cell num">
                  <form method="POST" action="/api/status-page-forms/{{ statusPage.id }}/monitors/remove">
                    <input type="hidden" name="monitor_id" value="{{ monitor.monitor_id }}" />
                    <button type="submit" class="tl-btn danger sm">Remove</button>
                  </form>
                </span>
              </div>
            @endforeach
          </div>
        @endif

        @if (availableMonitors.length > 0)
          <label class="tl-label" for="sp-add-monitor">Attach unit</label>
          <form method="POST" action="/api/status-page-forms/{{ statusPage.id }}/monitors/add" class="tl-attach-row">
            <select id="sp-add-monitor" name="monitor_id" class="tl-select">
              @foreach (availableMonitors as monitor)
                <option value="{{ monitor.id }}">{{ monitor.name }} ({{ monitor.type.replace('_', ' ').toUpperCase() }})</option>
              @endforeach
            </select>
            <button type="submit" class="tl-btn">Attach</button>
          </form>
        @endif

        @if (availableMonitors.length === 0 && assignedMonitors.length > 0)
          <span class="tl-label" style="margin: 0;">All team units are attached to this channel.</span>
        @endif
      </div>
    </section>

    @if (componentGroups.length > 0)
      <section class="tl-panel" aria-label="Component groups">
        <div class="tl-panel-head">
          <span>[ COMPONENT GROUPS ]</span>
          <span class="hz">{{ componentGroups.length }} GROUP{{ componentGroups.length === 1 ? '' : 'S' }}</span>
        </div>
        <div class="tl-panel-body">
          <div style="display: flex; flex-wrap: wrap; gap: 4px;">
            @foreach (componentGroups as group)
              <span class="tl-chip">{{ group.name }}</span>
            @endforeach
          </div>
        </div>
      </section>
    @endif

    @if (maintenanceWindows.length > 0)
      <section class="tl-panel" aria-label="Maintenance windows">
        <div class="tl-panel-head">
          <span>[ MAINTENANCE WINDOWS ]</span>
          <span class="hz">LAST {{ maintenanceWindows.length }}</span>
        </div>
        <div class="tl-panel-body" style="padding: 0;">
          <div class="tl-table" style="border: 0;">
            <div class="tl-thead" style="grid-template-columns: minmax(0, 1.4fr) 130px minmax(0, 1fr);">
              <span class="tl-cell">Window</span>
              <span class="tl-cell">State</span>
              <span class="tl-cell num">Schedule</span>
            </div>
            @foreach (maintenanceWindows as mw)
              <div class="tl-row" style="grid-template-columns: minmax(0, 1.4fr) 130px minmax(0, 1fr);">
                <span class="tl-cell tl-ellipsis" style="font-weight: 700;">{{ mw.title }}</span>
                <span class="tl-cell"><data class="{{ mwClass(mw.status) }}" value="{{ mw.status }}">{{ String(mw.status || 'UNKNOWN').toUpperCase() }}</data></span>
                <span class="tl-cell num sub"><time>{{ formatDate(mw.starts_at) }} -&gt; {{ formatDate(mw.ends_at) }}</time></span>
              </div>
            @endforeach
          </div>
        </div>
      </section>
    @endif

    <footer class="tl-footnote">
      <span>CHANNEL #{{ statusPage.id }} / {{ assignedMonitors.length }} UNIT{{ assignedMonitors.length === 1 ? '' : 'S' }} ON FEED</span>
      <span>UPTIME///STATUS © TELEMETRY CONSOLE</span>
    </footer>
  @endif
</main>
