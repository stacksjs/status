<!--
  Status page list + create form — dashboard page (stacksjs/status#1
  Phase 8). Same server-rendered convention as monitors/index.stx. The
  create form is a native HTML POST (no client JS) to
  Actions/StatusPages/DashboardCreateStatusPageAction.

  Visual language: Tactical Telemetry (.claude/skills/stacks-design-
  brutalist) via partials/telemetry-head.stx. Phosphor green marks
  PUBLIC/operational readouts only; hazard red marks limits and locks.
-->
<script server>
const Database = require('bun:sqlite').Database
const path = require('path')
const { config } = require('@stacksjs/config')
const { Auth, sessionUser } = require('@stacksjs/auth')

const dbPath = path.resolve(process.cwd(), process.env.DB_DATABASE_PATH || 'database/stacks.sqlite')
const db = new Database(dbPath, { readonly: true })

// Auth + team resolution — see resources/views/dashboard/monitors/
// index.stx's copy of this block for the full rationale. This page
// used to hardcode team #1 for every visitor.
async function resolveAuthTeam() {
  const guardName = config.auth?.default || 'api'
  const guard = config.auth?.guards?.[guardName] || {}
  const driver = guard.driver || 'token'
  const cookieName = driver === 'session' ? 'session_id' : (config.auth?.defaultTokenName || 'auth-token')

  const cookieValue = (typeof globalThis !== 'undefined' && globalThis.requestContext)
    ? globalThis.requestContext.cookie(cookieName)
    : null
  if (!cookieValue) return null

  const user = driver === 'session' ? await sessionUser(cookieValue) : await Auth.getUserFromToken(cookieValue)
  if (!user || !user.id) return null

  const membership = db.query(`
    SELECT team_id FROM team_members
    WHERE user_id = ?1 AND status = 'active'
    ORDER BY CASE WHEN role = 'owner' THEN 0 WHEN role = 'admin' THEN 1 ELSE 2 END
    LIMIT 1
  `).get(user.id)

  return { user, teamId: membership ? membership.team_id : null }
}

const AUTH = await resolveAuthTeam()
const AUTH_USER = AUTH ? AUTH.user : null
const TEAM_ID = AUTH && AUTH.teamId ? AUTH.teamId : -1
const NAV_ACTIVE = 'status-pages'

const statusPages = db.query(`SELECT id, slug, title, is_public, access_type, custom_domain FROM status_pages WHERE team_id = ?1 ORDER BY title ASC`).all(TEAM_ID)

const limitError = (typeof __stxServeSearch !== 'undefined' && __stxServeSearch) ? __stxServeSearch.includes('error=limit') : false

// Display-only helpers below: none of these touch queries or auth.
const publicCount = statusPages.filter((p) => p.access_type === 'public').length
const restrictedCount = statusPages.length - publicCount
const domainCount = statusPages.filter((p) => p.custom_domain).length

function accessLabel(t) {
  if (t === 'public') return 'PUBLIC'
  if (t === 'password') return 'PASSWORD'
  if (t === 'email_domain') return 'EMAIL DOMAIN'
  if (t === 'ip_allowlist') return 'IP ALLOWLIST'
  return String(t || 'UNKNOWN').toUpperCase()
}

const generatedAt = new Date().toISOString().replace('T', ' ').slice(0, 19)
</script>

@include('../partials/telemetry-head.stx')
@include('../partials/telemetry-nav.stx')

<style>
  .tl-alert {
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 24px 0 0;
    padding: 12px 16px;
    border: 1px solid var(--hazard);
    background: var(--panel);
    color: var(--hazard);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .tl-alert .why { color: var(--dim); font-weight: 400; }
  .tl-form-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 16px;
    margin-bottom: 16px;
  }
</style>

<main class="tl-shell">
  @if (!AUTH_USER)
    <div class="tl-empty" style="margin: 48px 0;">
      <span class="big">[ NO ACTIVE SESSION ]</span>
      <span class="why">Authentication required to read broadcast channels. <a href="/login" data-no-router style="color: var(--ink); text-decoration: underline;">Sign in</a>.</span>
    </div>
  @endif

  @if (AUTH_USER)
    <header class="tl-banner">
      <h1 class="tl-title">Status Pages</h1>
      <div class="tl-banner-meta">
        <span>{{ statusPages.length }} CHANNEL{{ statusPages.length === 1 ? '' : 'S' }} BROADCASTING</span>
        <span>{{ domainCount }} CUSTOM DOMAIN{{ domainCount === 1 ? '' : 'S' }}</span>
        <span class="hz">PUBLIC UPLINK /// {{ generatedAt }} UTC</span>
      </div>
    </header>

    @if (limitError)
      <div class="tl-alert" role="alert">
        <span>[ LIMIT REACHED ]</span>
        <span class="why">Status page limit reached for the current plan. Upgrade to add more.</span>
      </div>
    @endif

    <dl class="tl-stats">
      <div class="tl-stat">
        <dt>[ Channels ]</dt>
        <dd><output>{{ statusPages.length }}</output></dd>
      </div>
      <div class="tl-stat">
        <dt>[ Public ]</dt>
        <dd class="{{ publicCount > 0 ? 'ok' : '' }}"><output>{{ publicCount }}</output></dd>
      </div>
      <div class="tl-stat">
        <dt>[ Restricted ]</dt>
        <dd><output>{{ restrictedCount }}</output></dd>
      </div>
      <div class="tl-stat">
        <dt>[ Custom domains ]</dt>
        <dd><output>{{ domainCount }}</output></dd>
      </div>
    </dl>

    @if (statusPages.length === 0)
      <div class="tl-empty" style="margin: 24px 0;">
        <span class="big">[ NO BROADCAST CHANNELS ]</span>
        <span class="why">No status pages registered for this team. Provision the first one below.</span>
      </div>
    @endif

    @if (statusPages.length > 0)
      <section class="tl-table" style="margin: 24px 0;" aria-label="Status pages">
        <div class="tl-thead" style="grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr) minmax(0, 1fr) 140px 110px;">
          <span class="tl-cell">Name</span>
          <span class="tl-cell">Route</span>
          <span class="tl-cell">Custom domain</span>
          <span class="tl-cell">Access</span>
          <span class="tl-cell num">Visibility</span>
        </div>
        @foreach (statusPages as page)
          <a class="tl-row" href="/dashboard/status-pages/{{ page.id }}" style="grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr) minmax(0, 1fr) 140px 110px;">
            <span class="tl-cell tl-ellipsis" style="font-weight: 700;">{{ page.title }}</span>
            <span class="tl-cell sub tl-ellipsis"><samp>/status/{{ page.slug }}</samp></span>
            <span class="tl-cell sub tl-ellipsis">{{ page.custom_domain || '--' }}</span>
            <span class="tl-cell sub" style="text-transform: uppercase; letter-spacing: 0.08em;">{{ accessLabel(page.access_type) }}</span>
            <span class="tl-cell num"><data class="{{ page.is_public ? 'st st-up' : 'st st-unknown' }}" value="{{ page.is_public }}">{{ page.is_public ? 'LIVE' : 'HIDDEN' }}</data></span>
          </a>
        @endforeach
      </section>
    @endif

    <section class="tl-panel" aria-label="Create status page">
      <div class="tl-panel-head">
        <span>[ NEW STATUS PAGE ]</span>
        <span class="hz">PROVISION CHANNEL</span>
      </div>
      <div class="tl-panel-body">
        <form method="POST" action="/api/status-page-forms/create">
          <input type="hidden" name="team_id" value="{{ TEAM_ID }}" />
          <div class="tl-form-grid">
            <div>
              <label class="tl-label" for="sp-title">Title</label>
              <input id="sp-title" type="text" name="title" required class="tl-input" placeholder="ACME STATUS" />
            </div>
            <div>
              <label class="tl-label" for="sp-slug">Slug</label>
              <input id="sp-slug" type="text" name="slug" required class="tl-input" placeholder="orozco" />
              <span class="tl-label" style="margin: 6px 0 0;">Public route: /status/&lt;slug&gt;</span>
            </div>
          </div>
          <button type="submit" class="tl-btn">Create channel</button>
        </form>
      </div>
    </section>

    <footer class="tl-footnote">
      <span>CHANNEL COUNT {{ statusPages.length }} / TEAM {{ TEAM_ID }}</span>
      <span>UPTIME///STATUS © TELEMETRY CONSOLE</span>
    </footer>
  @endif
</main>
