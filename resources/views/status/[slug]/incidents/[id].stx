@extends('layouts/status')

<script server>
const { decrypt } = require('@stacksjs/security')
// Dialect-agnostic DB access via the framework query builder (works on
// sqlite for self-hosted single-box installs and on the networked
// Postgres the hosted multi-region fleet uses) — replaces the direct
// bun:sqlite file handle these views used to open. Joins are split into
// separate lookups rather than a single JOIN because the fluent builder's
// aliased-join projection is unreliable.
const { db } = require('@stacksjs/database')

const pageSlug = (typeof slug !== 'undefined' && slug) ? String(slug) : ''
const incidentId = Number((typeof id !== 'undefined' && id) || 0)

const statusPage = pageSlug
  ? (await db.selectFrom('status_pages').where('slug', '=', pageSlug).where('is_public', '=', true).limit(1).execute())[0] || null
  : null

// Access control (stacksjs/status#1 Phase 12). Without this the incident
// detail leaks the full incident/monitor/timeline of a password-, email-, or
// IP-gated page to anyone who guesses /status/{slug}/incidents/{id} — the
// parent [slug].stx gate is meaningless if this sibling view skips it. Same
// inline/self-contained-per-view convention documented in [slug].stx; KEEP IN
// SYNC with app/Actions/StatusPages/AccessControl.ts (the canonical version).
function ipv4ToInt(ip) {
  const parts = String(ip).trim().split('.')
  if (parts.length !== 4) return null
  let result = 0
  for (const part of parts) {
    if (!/^\d{1,3}$/.test(part)) return null
    const n = Number(part)
    if (n < 0 || n > 255) return null
    result = (result << 8) | n
  }
  return result >>> 0
}

function ipv6ToBigInt(ip) {
  let s = String(ip).trim()
  const pct = s.indexOf('%')
  if (pct !== -1) s = s.slice(0, pct)
  if (s.length === 0 || s.includes(':::')) return null
  const doubleColon = s.indexOf('::')
  if (doubleColon !== -1 && s.indexOf('::', doubleColon + 1) !== -1) return null
  const expandTail = (groups) => {
    if (groups.length === 0) return groups
    const last = groups[groups.length - 1]
    if (!last.includes('.')) return groups
    const v4 = ipv4ToInt(last)
    if (v4 === null) return null
    return [...groups.slice(0, -1), ((v4 >>> 16) & 0xFFFF).toString(16), (v4 & 0xFFFF).toString(16)]
  }
  let groups
  if (doubleColon === -1) {
    const expanded = expandTail(s.split(':'))
    if (expanded === null || expanded.length !== 8) return null
    groups = expanded
  }
  else {
    const leftRaw = s.slice(0, doubleColon) ? s.slice(0, doubleColon).split(':') : []
    const rightRaw = s.slice(doubleColon + 2) ? s.slice(doubleColon + 2).split(':') : []
    const right = expandTail(rightRaw)
    if (right === null) return null
    const fill = 8 - leftRaw.length - right.length
    if (fill < 1) return null
    groups = [...leftRaw, ...Array.from({ length: fill }, () => '0'), ...right]
  }
  let result = 0n
  for (const g of groups) {
    if (!/^[0-9a-f]{1,4}$/i.test(g)) return null
    result = (result << 16n) | BigInt(Number.parseInt(g, 16))
  }
  return result
}

function matchCidr4(ipInt, range) {
  if (!range.includes('/')) return ipv4ToInt(range) === ipInt
  const [base, bitsStr] = range.split('/')
  const baseInt = ipv4ToInt(base)
  const bits = Number(bitsStr)
  if (baseInt === null || !Number.isInteger(bits) || bits < 0 || bits > 32) return false
  const mask = bits === 0 ? 0 : (0xFFFFFFFF << (32 - bits)) >>> 0
  return (ipInt & mask) === (baseInt & mask)
}

function matchCidr6(ipBig, range) {
  if (!range.includes('/')) {
    const only = ipv6ToBigInt(range)
    return only !== null && only === ipBig
  }
  const [base, bitsStr] = range.split('/')
  const baseBig = ipv6ToBigInt(base)
  const bits = Number(bitsStr)
  if (baseBig === null || !Number.isInteger(bits) || bits < 0 || bits > 128) return false
  const full = (1n << 128n) - 1n
  const mask = bits === 0 ? 0n : (full << BigInt(128 - bits)) & full
  return (ipBig & mask) === (baseBig & mask)
}

function isIpAllowed(ip, ranges) {
  if (!ip || ranges.length === 0) return false
  let v4 = null
  let v6 = null
  const s = String(ip).trim()
  if (s.startsWith('::ffff:') && s.includes('.')) { v4 = ipv4ToInt(s.slice(7)); v6 = ipv6ToBigInt(s) }
  else if (s === '::1') { v6 = ipv6ToBigInt(s); v4 = ipv4ToInt('127.0.0.1') }
  else if (s.includes(':')) { v6 = ipv6ToBigInt(s) }
  else { v4 = ipv4ToInt(s) }
  if (v4 === null && v6 === null) return false
  return ranges.some((range) => {
    const trimmed = range.trim()
    if (!trimmed) return false
    return trimmed.includes(':')
      ? (v6 !== null && matchCidr6(v6, trimmed))
      : (v4 !== null && matchCidr4(v4, trimmed))
  })
}

let accessGranted = true
if (statusPage && statusPage.access_type && statusPage.access_type !== 'public') {
  if (statusPage.access_type === 'ip_allowlist') {
    let allowedRanges = []
    try { allowedRanges = JSON.parse(statusPage.allowed_ip_ranges || '[]') } catch {}
    accessGranted = isIpAllowed(typeof ip !== 'undefined' ? ip : '', allowedRanges)
  }
  else {
    // 'password' / 'email_domain' — gated by the unlock cookie
    // UnlockStatusPageAction sets on success.
    const cookieValue = (typeof cookies !== 'undefined' && cookies) ? cookies['status_unlock_' + pageSlug] : undefined
    accessGranted = false
    if (cookieValue) {
      try {
        const decoded = await decrypt(decodeURIComponent(cookieValue))
        accessGranted = decoded === `unlock:${statusPage.id}`
      }
      catch {
        accessGranted = false
      }
    }
  }
}

let incident = null
if (statusPage && accessGranted && incidentId) {
  const inc = (await db.selectFrom('incidents').where('id', '=', incidentId).limit(1).execute())[0]
  if (inc) {
    // Only expose the incident if its monitor is actually attached to this page.
    const link = (await db.selectFrom('status_page_monitors')
      .where('status_page_id', '=', statusPage.id)
      .where('monitor_id', '=', inc.monitor_id)
      .limit(1).execute())[0]
    if (link) {
      const monitor = (await db.selectFrom('monitors').where('id', '=', inc.monitor_id).limit(1).execute())[0]
      incident = { ...inc, monitor_name: monitor ? monitor.name : '' }
    }
  }
}

const updates = incident
  ? await db.selectFrom('incident_updates').where('incident_id', '=', incident.id).orderBy('posted_at', 'asc').execute()
  : []

const pageTitle = incident ? `${incident.monitor_name} incident` : 'Incident not found'

function formatDate(iso) {
  if (!iso) return ''
  const d = new Date(iso)
  return d.toLocaleString('en-US', { month: 'short', day: 'numeric', year: 'numeric', hour: 'numeric', minute: '2-digit' })
}

function statusBadgeClass(status) {
  if (status === 'resolved') return 'text-xs font-medium uppercase tracking-wide text-emerald-600'
  if (status === 'monitoring') return 'text-xs font-medium uppercase tracking-wide text-sky-600'
  return 'text-xs font-medium uppercase tracking-wide text-amber-600'
}

// Title + favicon for this fragment view (see the status page's note).
useHead({
  title: incident ? 'Incident: ' + (incident.monitor_name || 'details') : 'Incident',
  link: [
    { rel: 'icon', href: '/favicon.svg', type: 'image/svg+xml' },
    { rel: 'icon', href: '/favicon-32.png', type: 'image/png', sizes: '32x32' },
    { rel: 'apple-touch-icon', href: '/apple-touch-icon.png' },
  ],
})
</script>

@section('title', pageTitle)
@section('description', 'Incident detail and timeline')

@section('content')
  <div class="mx-auto max-w-2xl px-6 py-16">

    @if (!incident)
      <div class="py-24 text-center">
        <p class="text-sm font-medium uppercase tracking-wide text-gray-400">404</p>
        <h1 class="mt-2 text-2xl font-semibold text-gray-900">Incident not found</h1>
      </div>
    @endif

    @if (incident)
      <a href="/status/{{ pageSlug }}" class="text-sm text-gray-500 hover:text-gray-900">&larr; Back to status</a>

      <header class="mt-4 mb-8">
        <p class="{{ statusBadgeClass(incident.status) }}">{{ incident.status }}</p>
        <h1 class="mt-2 text-2xl font-semibold text-gray-900">{{ incident.monitor_name }}</h1>
        <p class="mt-2 text-gray-600">{{ incident.cause }}</p>
      </header>

      <div class="space-y-6 border-l-2 border-gray-200 pl-6">
        <div>
          <p class="text-sm font-medium text-gray-900">Incident started</p>
          <p class="text-sm text-gray-500">{{ formatDate(incident.started_at) }}</p>
        </div>

        @foreach (updates as update)
          <div>
            <p class="{{ statusBadgeClass(update.status) }}">{{ update.status }}</p>
            <p class="mt-1 text-sm text-gray-700">{{ update.message }}</p>
            <p class="mt-1 text-sm text-gray-500">{{ formatDate(update.posted_at) }}</p>
          </div>
        @endforeach

        @if (incident.resolved_at)
          <div>
            <p class="text-sm font-medium text-emerald-700">Resolved</p>
            <p class="text-sm text-gray-500">{{ formatDate(incident.resolved_at) }}</p>
          </div>
        @endif
      </div>
    @endif

  </div>
@endsection
